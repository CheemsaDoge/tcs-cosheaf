{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/CheemsaDoge/tcs-cosheaf/schemas/research_loop.schema.json",
  "title": "ResearchLoop",
  "description": "Main research loop model, coordinates multiple bounded attempts.",
  "type": "object",
  "required": ["loop_id", "issue_id", "status", "attempts", "max_attempts", "budget", "created_at", "authority_notice"],
  "properties": {
    "loop_id": {
      "type": "string",
      "description": "Unique loop identifier",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "description": "Issue this loop targets",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["active", "paused", "finalized"],
      "description": "Lifecycle state for the research loop"
    },
    "attempts": {
      "type": "array",
      "description": "Ordered list of attempts",
      "items": {
        "$ref": "research_loop_attempt.schema.json"
      }
    },
    "max_attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 100,
      "description": "Maximum number of attempts allowed"
    },
    "budget": {
      "type": "object",
      "description": "Resource budgets (tokens, time, etc.)",
      "additionalProperties": {
        "type": ["integer", "number"]
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Loop creation time"
    },
    "finalized_at": {
      "type": ["string", "null"],
      "format": "date-time",
      "description": "When loop was finalized"
    },
    "notes": {
      "type": "string",
      "description": "Operator notes",
      "default": ""
    },
    "authority_notice": {
      "type": "string",
      "description": "Authority disclaimer"
    }
  },
  "additionalProperties": false
}
