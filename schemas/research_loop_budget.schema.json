{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CheemsaDoge/tcs-cosheaf/schemas/research_loop_budget.schema.json",
  "title": "ResearchLoopBudget",
  "type": "object",
  "required": ["max_attempts"],
  "properties": {
    "max_attempts": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000
    },
    "max_wallclock_minutes": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "max_tokens": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "notes": {
      "type": ["string", "null"]
    }
  },
  "additionalProperties": false
}
