{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/review.schema.json",
  "title": "TCS-Cosheaf Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "status",
    "created_at",
    "updated_at",
    "authors",
    "target",
    "summary",
    "findings",
    "decision"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "review"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["draft", "human_reviewed", "accepted"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target": {
      "type": "string"
    },
    "summary": {
      "type": "string"
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "request_changes",
        "reject",
        "informational",
        "accept_for_private_use",
        "accept_for_public_candidate",
        "changes_requested",
        "keep_draft",
        "refute_candidate",
        "mark_obsolete"
      ]
    }
  }
}
