{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/task.schema.json",
  "title": "TCS-Cosheaf Agent Task",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "issue_id",
    "worker_type",
    "status",
    "input_context",
    "budget",
    "expected_outputs",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "issue_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_type": {
      "type": "string",
      "enum": [
        "reasoner",
        "verifier",
        "counterexampleer",
        "construction_searcher",
        "formalizer",
        "literature_scout",
        "orchestrator"
      ]
    },
    "status": {
      "type": "string",
      "enum": [
        "open",
        "in_progress",
        "blocked",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "input_context": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": {
        "type": ["boolean", "integer", "number", "string"]
      }
    },
    "expected_outputs": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
