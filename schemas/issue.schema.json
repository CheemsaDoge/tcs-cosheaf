{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/issue.schema.json",
  "title": "TCS-Cosheaf Issue",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "status",
    "created_at",
    "updated_at",
    "authors",
    "related_artifacts"
  ],
  "anyOf": [
    {
      "required": ["summary"]
    },
    {
      "required": ["description"]
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "issue"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": ["open", "blocked", "closed"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "severity": {
      "type": "string",
      "enum": ["low", "medium", "high"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "related_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "labels": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "related_sources": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "parent_issue": {
      "type": "string"
    },
    "external_links": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "scope": {
      "type": "string",
      "enum": ["private", "public"],
      "default": "private"
    },
    "close_reason": {
      "type": "string",
      "minLength": 1
    }
  }
}
