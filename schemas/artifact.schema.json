{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/artifact.schema.json",
  "title": "TCS-Cosheaf Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "type",
    "title",
    "domain",
    "status",
    "created_at",
    "updated_at",
    "authors",
    "depends_on",
    "supersedes",
    "tags",
    "statement",
    "evidence",
    "review",
    "risk"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "definition",
        "claim",
        "theorem",
        "conjecture",
        "proof",
        "proof_attempt",
        "construction",
        "algorithm",
        "reduction",
        "counterexample",
        "experiment",
        "review",
        "verifier",
        "issue"
      ]
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "status": {
      "$ref": "#/$defs/status"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "depends_on": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "supersedes": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "statement": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "path", "summary"],
        "properties": {
          "kind": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "paper",
              "book",
              "survey",
              "lecture_note",
              "website",
              "internal_note",
              "other"
            ]
          },
          "title": {
            "type": "string"
          },
          "authors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "year": {
            "type": ["integer", "null"],
            "minimum": 1
          },
          "doi": {
            "type": "string"
          },
          "arxiv": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "theorem_number": {
            "type": "string"
          },
          "page": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "formalizations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "system",
          "library",
          "library_ref",
          "import_path",
          "symbol",
          "declaration_kind",
          "status",
          "check_mode"
        ],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9]*(?:-[a-z0-9]+)*(?:\\.(?:[a-z][a-z0-9]*(?:-[a-z0-9]+)*|[0-9]+))+$"
          },
          "system": {
            "type": "string",
            "enum": ["lean4"]
          },
          "library": {
            "type": "string",
            "pattern": ".*\\S.*"
          },
          "library_ref": {
            "type": "string",
            "pattern": ".*\\S.*"
          },
          "import_path": {
            "type": "string",
            "pattern": ".*\\S.*"
          },
          "symbol": {
            "type": "string",
            "pattern": ".*\\S.*"
          },
          "declaration_kind": {
            "type": "string",
            "enum": [
              "definition",
              "theorem",
              "lemma",
              "instance",
              "structure",
              "other"
            ]
          },
          "status": {
            "type": "string",
            "enum": ["planned", "linked", "checked", "broken", "deprecated"]
          },
          "check_mode": {
            "type": "string",
            "enum": ["external_library_ref", "local_file"]
          },
          "expected_type": {
            "type": "string"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "alignment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["none", "requested", "human_reviewed", "rejected"]
        },
        "reviewer": {
          "type": "string"
        },
        "reviewed_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "convention_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "limitations": {
          "type": "string"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": ["human_reviewed", "rejected"]
              }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["reviewer"],
            "properties": {
              "reviewer": {
                "type": "string",
                "pattern": ".*\\S.*"
              }
            }
          }
        }
      ]
    },
    "verification_policy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "level": {
          "type": "string",
          "enum": [
            "source_reviewed",
            "source_reviewed_with_formal_link",
            "machine_checked",
            "lean_required"
          ]
        },
        "require_formal_link": {
          "type": "boolean"
        },
        "require_lean_check": {
          "type": "boolean"
        },
        "require_alignment_review": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "level": {
                "const": "source_reviewed_with_formal_link"
              }
            },
            "required": ["level"]
          },
          "then": {
            "required": ["require_formal_link"],
            "properties": {
              "require_formal_link": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "level": {
                "const": "lean_required"
              }
            },
            "required": ["level"]
          },
          "then": {
            "required": ["require_formal_link", "require_lean_check"],
            "properties": {
              "require_formal_link": {
                "const": true
              },
              "require_lean_check": {
                "const": true
              }
            }
          }
        }
      ]
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["state", "notes"],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "none",
            "requested",
            "in_review",
            "approved",
            "changes_requested",
            "human_reviewed",
            "accepted"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["level", "notes"],
      "properties": {
        "level": {
          "type": "string",
          "enum": ["low", "medium", "high"]
        },
        "notes": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "status": {
      "type": "string",
      "enum": [
        "raw",
        "draft",
        "locally_tested",
        "adversarially_tested",
        "machine_checked",
        "human_reviewed",
        "accepted",
        "refuted",
        "obsolete",
        "superseded"
      ]
    }
  }
}
