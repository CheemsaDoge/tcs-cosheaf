{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/site_export.schema.json",
  "title": "TCS-Cosheaf Website Export Payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "kind", "authority_notice"],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "site",
        "workspace",
        "artifacts",
        "issues",
        "graph",
        "gates",
        "context_packs",
        "reports",
        "authority_boundaries"
      ]
    },
    "authority_notice": {
      "type": "string",
      "minLength": 1
    }
  }
}
