{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CheemsaDoge/tcs-cosheaf/schemas/research_loop_run_result.schema.json",
  "title": "ResearchLoopRunResult",
  "description": "Bounded deterministic research-loop runner or dry-run result.",
  "type": "object",
  "required": [
    "loop_id",
    "mode",
    "dry_run",
    "planned_actions",
    "writes_performed",
    "stop_conditions",
    "authority_notice"
  ],
  "properties": {
    "loop_id": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["dry_run", "local"] },
    "dry_run": { "type": "boolean" },
    "planned_actions": {
      "type": "array",
      "items": { "$ref": "research_loop_next_result.schema.json" }
    },
    "writes_performed": { "type": "boolean" },
    "stop_conditions": {
      "type": "array",
      "items": { "$ref": "research_loop_stop_condition.schema.json" }
    },
    "authority_notice": { "type": "string" }
  },
  "additionalProperties": false
}
