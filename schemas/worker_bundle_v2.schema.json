{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/worker_bundle_v2.schema.json",
  "title": "TCS-Cosheaf Worker Bundle v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundle_id",
    "task_id",
    "worker_role",
    "created_at",
    "summary",
    "used_artifacts",
    "used_sources",
    "claims",
    "proposed_artifacts",
    "verification_requests",
    "failures_or_counterexamples",
    "risk_flags",
    "next_steps",
    "confidence"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "task_id": {
      "type": "string",
      "minLength": 1
    },
    "worker_role": {
      "$ref": "#/$defs/worker_type"
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "used_artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "used_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "claims": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "proposed_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/proposed_artifact"
      }
    },
    "assumptions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "uncertainty": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "verification_requests": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "failed_attempts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "counterexamples": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "counterexample_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/counterexample_candidate"
      },
      "uniqueItems": true
    },
    "failures_or_counterexamples": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "dependency_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "confidence": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    }
  },
  "$defs": {
    "worker_type": {
      "type": "string",
      "enum": [
        "reasoner",
        "verifier",
        "counterexampleer",
        "construction_searcher",
        "formalizer",
        "literature_scout",
        "orchestrator"
      ]
    },
    "proposed_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "summary"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "counterexample_candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "construction_summary",
        "evidence_paths",
        "verifier_request_ids",
        "status",
        "limitations"
      ],
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "target_claim": {
          "type": [
            "string",
            "null"
          ]
        },
        "construction_summary": {
          "type": "string",
          "minLength": 1
        },
        "evidence_paths": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "verifier_request_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          },
          "uniqueItems": true
        },
        "status": {
          "type": "string",
          "enum": [
            "proposed",
            "needs_check",
            "checked_false",
            "checked_true",
            "rejected",
            "superseded"
          ]
        },
        "limitations": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "enum": [
                  "checked_false",
                  "checked_true"
                ]
              }
            },
            "required": [
              "status"
            ]
          },
          "then": {
            "properties": {
              "evidence_paths": {
                "minItems": 1
              }
            }
          }
        }
      ]
    }
  }
}
