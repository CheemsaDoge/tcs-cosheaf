{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/CheemsaDoge/tcs-cosheaf/schemas/attempt_failure_record.schema.json",
  "title": "AttemptFailureRecord",
  "description": "Structured failure record for one bounded attempt.",
  "type": "object",
  "required": [
    "failure_id",
    "attempt_id",
    "attempted_direction",
    "why_it_failed",
    "evidence_for_failure",
    "related_artifacts",
    "related_previous_attempts",
    "counterexample_candidate_ids",
    "checked_counterexample_ids",
    "verifier_or_gate_errors",
    "should_retry",
    "avoid_in_future",
    "tags",
    "signature",
    "occurred_at"
  ],
  "properties": {
    "failure_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "attempted_direction": {
      "type": "string",
      "minLength": 1
    },
    "why_it_failed": {
      "type": "string",
      "minLength": 1
    },
    "evidence_for_failure": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "related_artifacts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_previous_attempts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "counterexample_candidate_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checked_counterexample_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "verifier_or_gate_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "should_retry": {
      "type": "boolean"
    },
    "retry_conditions": {
      "type": ["string", "null"]
    },
    "avoid_in_future": {
      "type": "string",
      "minLength": 1
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "invalid_approach",
          "missing_dependency",
          "insufficient_evidence",
          "formal_mismatch",
          "counterexample_found",
          "timeout",
          "resource_exhausted",
          "tooling_unavailable",
          "blocked_by_policy",
          "unknown"
        ]
      }
    },
    "signature": {
      "type": "string",
      "minLength": 1
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "additionalProperties": false
}
