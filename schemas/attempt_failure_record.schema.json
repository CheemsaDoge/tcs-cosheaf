{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/CheemsaDoge/tcs-cosheaf/schemas/attempt_failure_record.schema.json",
  "title": "AttemptFailureRecord",
  "description": "Structured failure record for one attempt.",
  "type": "object",
  "required": ["tags", "description", "occurred_at"],
  "properties": {
    "tags": {
      "type": "array",
      "description": "Failure classification tags",
      "items": {
        "type": "string",
        "enum": [
          "verifier_fail",
          "gate_fail",
          "dependency_missing",
          "proof_gap",
          "resource_exhausted",
          "blocked_external",
          "invalid_direction",
          "other"
        ]
      },
      "minItems": 1
    },
    "description": {
      "type": "string",
      "description": "Human-readable failure explanation",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "description": "Evidence paths or artifact IDs",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time",
      "description": "When this failure occurred"
    }
  },
  "additionalProperties": false
}
