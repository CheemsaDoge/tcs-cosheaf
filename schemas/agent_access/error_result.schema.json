{
  "additionalProperties": false,
  "description": "Standard machine-readable error response.",
  "properties": {
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "code": {
      "title": "Code",
      "type": "string"
    },
    "message": {
      "title": "Message",
      "type": "string"
    },
    "remediation": {
      "title": "Remediation",
      "type": "string"
    },
    "blocking": {
      "title": "Blocking",
      "type": "boolean"
    },
    "related_path": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Related Path"
    },
    "related_artifact": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Related Artifact"
    },
    "details": {
      "additionalProperties": {
        "type": "string"
      },
      "title": "Details",
      "type": "object"
    }
  },
  "required": [
    "code",
    "message",
    "remediation",
    "blocking"
  ],
  "title": "ErrorResult",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/agent_access/error_result.schema.json"
}
