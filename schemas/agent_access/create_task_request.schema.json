{
  "$defs": {
    "WorkerType": {
      "description": "Protocol-level worker roles supported by the agent harness.",
      "enum": [
        "reasoner",
        "verifier",
        "counterexampleer",
        "construction_searcher",
        "formalizer",
        "literature_scout",
        "orchestrator"
      ],
      "title": "WorkerType",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "description": "Request to create a local task record.",
  "properties": {
    "schema_version": {
      "const": 1,
      "default": 1,
      "title": "Schema Version",
      "type": "integer"
    },
    "issue_id": {
      "title": "Issue Id",
      "type": "string"
    },
    "worker_type": {
      "$ref": "#/$defs/WorkerType"
    }
  },
  "required": [
    "issue_id",
    "worker_type"
  ],
  "title": "CreateTaskRequest",
  "type": "object",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tcs-cosheaf.local/schemas/agent_access/create_task_request.schema.json"
}
