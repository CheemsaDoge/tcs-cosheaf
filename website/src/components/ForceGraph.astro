---
import I18nText from "./I18nText.astro";
import { localized, type LocalizedText } from "../lib/i18n";
import {
  GRAPH_PAGE_SIZE,
  artifactHref,
  type GraphEdge,
  type GraphNode
} from "../lib/siteData";

interface Props {
  id: string;
  nodes: GraphNode[];
  edges: GraphEdge[];
  centerId?: string;
  pageSize?: number;
  compact?: boolean;
  ariaLabel: LocalizedText;
}

const {
  id,
  nodes,
  edges,
  centerId = "",
  pageSize = GRAPH_PAGE_SIZE,
  compact = false,
  ariaLabel
} = Astro.props;
const dataId = `${id}-data`;
const nodeTypes = [...new Set(nodes.map((node) => node.artifact_type))].sort(
  (left, right) => left.localeCompare(right)
);
const graphData = JSON.stringify({
  nodes: nodes.map((node) => ({
    id: node.artifact_id,
    title: node.title,
    type: node.artifact_type,
    status: node.status,
    href: artifactHref(node.artifact_id)
  })),
  links: edges.map((edge) => ({
    source: edge.source_id,
    target: edge.target_id
  })),
  centerId,
  pageSize
}).replace(/</g, "\\u003c");
---

<div class:list={["obsidian-graph", { compact }]} id={id} data-force-graph>
  <div class="obsidian-graph-stage">
    <div
      class="obsidian-force-canvas"
      data-graph-canvas
      role="img"
      aria-label={ariaLabel.zh}
      data-i18n-aria-label-en={ariaLabel.en}
      data-i18n-aria-label-zh={ariaLabel.zh}
    ></div>
    <button
      type="button"
      class="graph-settings-toggle"
      data-graph-settings-toggle
      aria-expanded="false"
      aria-controls={`${id}-settings`}
    >
      <I18nText text={localized("Settings", "设置")} />
    </button>
  </div>

  <button
    type="button"
    class="graph-settings-scrim"
    data-graph-settings-scrim
    aria-label="Close graph settings"
    hidden
  ></button>
  <aside
    id={`${id}-settings`}
    class="obsidian-graph-settings"
    aria-label="图谱设置"
    data-i18n-aria-label-en="Graph settings"
    aria-hidden="true"
    data-open="false"
    data-i18n-aria-label-zh="图谱设置"
  >
    <div class="graph-settings-head">
      <strong><I18nText text={localized("Graph settings", "图谱设置")} /></strong>
      <button type="button" data-graph-reset>
        <I18nText text={localized("Reset", "重置")} />
      </button>
      <button type="button" data-graph-unpin>
        <I18nText text={localized("Unpin all", "取消全部固定")} />
      </button>
      <button type="button" data-graph-settings-close>
        <I18nText text={localized("Close", "关闭")} />
      </button>
    </div>

    <label class="graph-search">
      <I18nText text={localized("Search files", "搜索文件")} />
      <input
        type="search"
        data-graph-search
        placeholder="搜索文件或工件"
        data-i18n-placeholder-en="Search files or artifacts"
        data-i18n-placeholder-zh="搜索文件或工件"
      />
    </label>

    <details open>
      <summary><I18nText text={localized("Filters", "过滤")} /></summary>
      <div class="graph-checkbox-stack">
        <label>
          <input type="checkbox" data-graph-only-created checked disabled />
          <span><I18nText text={localized("Only existing notes", "仅显示已创建的笔记")} /></span>
        </label>
        <label>
          <input type="checkbox" data-graph-orphans checked />
          <span><I18nText text={localized("Orphan files", "孤立文件")} /></span>
        </label>
        <label class="disabled-control">
          <input type="checkbox" data-graph-tags disabled />
          <span><I18nText text={localized("Tags unavailable in this export", "此导出没有标签数据")} /></span>
        </label>
        <label class="disabled-control">
          <input type="checkbox" data-graph-attachments disabled />
          <span><I18nText text={localized("Attachments unavailable in this export", "此导出没有附件数据")} /></span>
        </label>
        {
          nodeTypes.map((type) => (
            <label>
              <input type="checkbox" data-graph-type={type} checked />
              <span>{type}</span>
            </label>
          ))
        }
      </div>
    </details>

    <details open>
      <summary><I18nText text={localized("Color groups", "颜色组")} /></summary>
      <div class="graph-checkbox-stack">
        <label>
          <input type="checkbox" data-graph-color-type checked />
          <span><I18nText text={localized("Artifact type colors", "按工件类型着色")} /></span>
        </label>
        <label>
          <input type="checkbox" data-graph-color-status />
          <span><I18nText text={localized("Status colors", "按状态着色")} /></span>
        </label>
      </div>
      <button type="button" class="graph-inline-button" data-graph-new-color-group>
        <I18nText text={localized("New color group", "新建颜色组")} />
      </button>
    </details>

    <details open>
      <summary><I18nText text={localized("Appearance", "外观")} /></summary>
      <label class="graph-checkbox-inline">
        <input type="checkbox" data-graph-arrows />
        <span><I18nText text={localized("Arrows", "箭头")} /></span>
      </label>
      <label class="graph-checkbox-inline">
        <input type="checkbox" data-graph-labels />
        <span><I18nText text={localized("Show labels", "显示标签")} /></span>
      </label>
      <label class="graph-checkbox-inline">
        <input type="checkbox" data-graph-pin-dragged />
        <span><I18nText text={localized("Pin after drag (off by default)", "拖拽后固定（默认关闭）")} /></span>
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Label zoom threshold", "标签显示缩放阈值")} /></span>
        <input type="range" min="0.5" max="3" value="1.4" step="0.1" data-graph-label-threshold />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Text opacity", "文本透明度")} /></span>
        <input type="range" min="0.1" max="1" value="0.9" step="0.05" data-graph-text-opacity />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Min links to show", "最小连接数")} /></span>
        <input type="range" min="0" max="5" value="0" step="1" data-graph-label-min-links />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Node size", "节点大小")} /></span>
        <input type="range" min="3" max="12" value="5" data-graph-node-size />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Link width", "连线粗细")} /></span>
        <input type="range" min="1" max="4" value="1.2" step="0.2" data-graph-link-width />
      </label>
    </details>

    <details>
      <summary><I18nText text={localized("Forces", "力参数")} /></summary>
      <label class="graph-slider">
        <span><I18nText text={localized("Center force", "图谱向心力")} /></span>
        <input type="range" min="0" max="1" value="0.24" step="0.02" data-graph-center-force />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Repel force", "节点间的排斥力")} /></span>
        <input type="range" min="120" max="900" value="240" step="30" data-graph-repel />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Link force", "相连节点间的吸引力")} /></span>
        <input type="range" min="0" max="1.5" value="0.7" step="0.05" data-graph-link-force />
      </label>
      <label class="graph-slider">
        <span><I18nText text={localized("Link distance", "连线长度")} /></span>
        <input type="range" min="40" max="260" value={centerId ? "110" : "70"} step="10" data-graph-link-distance />
      </label>
    </details>

    <div class="graph-page-controls">
      <button type="button" data-graph-prev>
        <I18nText text={localized("Previous", "上一页")} />
      </button>
      <output data-graph-page>1 / 1</output>
      <button type="button" data-graph-next>
        <I18nText text={localized("Next", "下一页")} />
      </button>
    </div>

    <p class="graph-authority-note">
      <I18nText
        text={localized(
          "Display context only. This graph does not review, verify, accept, or promote artifacts.",
          "仅为展示上下文；此图谱不审阅、不验证、不接受或提升工件。"
        )}
      />
    </p>
  </aside>
  <script id={dataId} type="application/json" set:html={graphData}></script>
</div>

<script>
  import ForceGraph from "force-graph";
  import { forceX, forceY } from "d3-force-3d";

  const initialized = new WeakSet();

  const initCosheafGraph = (host) => {
    if (initialized.has(host)) {
      return;
    }
    initialized.add(host);

    const dataElement = host.querySelector("script[type='application/json']");
    const canvasHost = host.querySelector("[data-graph-canvas]");
    if (!dataElement || !canvasHost) {
      return;
    }

    const payload = JSON.parse(dataElement.textContent || "{}");
    const allNodes = Array.isArray(payload.nodes) ? payload.nodes : [];
    const allLinks = Array.isArray(payload.links) ? payload.links : [];
    const centerId = payload.centerId || "";
    const pageSize = Math.max(1, Number(payload.pageSize) || allNodes.length || 1);
    const searchInput = host.querySelector("[data-graph-search]");
    const typeInputs = [...host.querySelectorAll("[data-graph-type]")];
    const orphansInput = host.querySelector("[data-graph-orphans]");
    const colorTypeInput = host.querySelector("[data-graph-color-type]");
    const colorStatusInput = host.querySelector("[data-graph-color-status]");
    const newColorGroupButton = host.querySelector("[data-graph-new-color-group]");
    const arrowsInput = host.querySelector("[data-graph-arrows]");
    const labelsInput = host.querySelector("[data-graph-labels]");
    const pinDraggedInput = host.querySelector("[data-graph-pin-dragged]");
    const labelThresholdInput = host.querySelector("[data-graph-label-threshold]");
    const textOpacityInput = host.querySelector("[data-graph-text-opacity]");
    const labelMinLinksInput = host.querySelector("[data-graph-label-min-links]");
    const nodeSizeInput = host.querySelector("[data-graph-node-size]");
    const linkWidthInput = host.querySelector("[data-graph-link-width]");
    const centerForceInput = host.querySelector("[data-graph-center-force]");
    const repelInput = host.querySelector("[data-graph-repel]");
    const linkForceInput = host.querySelector("[data-graph-link-force]");
    const linkDistanceInput = host.querySelector("[data-graph-link-distance]");
    const previousButton = host.querySelector("[data-graph-prev]");
    const nextButton = host.querySelector("[data-graph-next]");
    const resetButton = host.querySelector("[data-graph-reset]");
    const unpinButton = host.querySelector("[data-graph-unpin]");
    const pageOutput = host.querySelector("[data-graph-page]");
    const selectionOutput = host.querySelector("[data-graph-selection]");
    const settingsToggle = host.querySelector("[data-graph-settings-toggle]");
    const settingsPanel = host.querySelector(".obsidian-graph-settings");
    const settingsClose = host.querySelector("[data-graph-settings-close]");
    const settingsScrim = host.querySelector("[data-graph-settings-scrim]");
    const storageKey = `cosheaf.forceGraph.positions.${host.id || "graph"}.v1`;
    const linkEndpointId = (endpoint) =>
      endpoint && typeof endpoint === "object" ? endpoint.id : endpoint;
    const degreeById = new Map();
    for (const link of allLinks) {
      const sourceId = linkEndpointId(link.source);
      const targetId = linkEndpointId(link.target);
      degreeById.set(sourceId, (degreeById.get(sourceId) || 0) + 1);
      degreeById.set(targetId, (degreeById.get(targetId) || 0) + 1);
    }

    let page = 1;
    let selectedId = "";
    let hoverId = "";
    let positions = {};
    let settingsOpen = false;

    const setSettingsOpen = (open) => {
      settingsOpen = open;
      settingsPanel?.setAttribute("data-open", open ? "true" : "false");
      settingsPanel?.setAttribute("aria-hidden", open ? "false" : "true");
      settingsToggle?.setAttribute("aria-expanded", open ? "true" : "false");
      if (settingsScrim) {
        settingsScrim.hidden = !open;
      }
      if (open) {
        settingsPanel?.querySelector("input, button, select, textarea, summary")?.focus();
      } else {
        settingsToggle?.focus();
      }
    };

    const readPositions = () => {
      try {
        positions = JSON.parse(window.localStorage.getItem(storageKey) || "{}");
      } catch {
        positions = {};
      }
    };
    const writePositions = () => {
      try {
        window.localStorage.setItem(storageKey, JSON.stringify(positions));
      } catch {
        // Storage may be unavailable in hardened browser contexts.
      }
    };
    const currentLanguage = () =>
      document.documentElement.dataset.lang === "en" ? "en" : "zh";
    const activeTypes = () =>
      new Set(
        typeInputs
          .filter((input) => input.checked)
          .map((input) => input.getAttribute("data-graph-type"))
      );
    const searchTerm = () => String(searchInput?.value || "").trim().toLowerCase();
    const nodeRole = (nodeId) => {
      if (centerId && nodeId === centerId) {
        return "center";
      }
      if (
        centerId &&
        allLinks.some(
          (link) =>
            linkEndpointId(link.source) === centerId &&
            linkEndpointId(link.target) === nodeId
        )
      ) {
        return "dependency";
      }
      if (
        centerId &&
        allLinks.some(
          (link) =>
            linkEndpointId(link.target) === centerId &&
            linkEndpointId(link.source) === nodeId
        )
      ) {
        return "dependent";
      }
      return "default";
    };
    const typePalette = new Map(
      [...new Set(allNodes.map((node) => node.type))].map((type, index) => [
        type,
        ["#c4612f", "#78a399", "#c89b55", "#8f7bb8", "#9aa39a"][index % 5]
      ])
    );
    const nodeColor = (node) => {
      if (node.id === selectedId || node.id === hoverId) {
        return "#f4c95d";
      }
      if (colorTypeInput?.checked) {
        return typePalette.get(node.type) || "#9aa39a";
      }
      if (node.role === "center") {
        return "#c4612f";
      }
      if (node.role === "dependency") {
        return "#c89b55";
      }
      if (node.role === "dependent") {
        return "#78a399";
      }
      return node.status === "accepted" ? "#9aa39a" : "#6f766f";
    };
    const isLinkedToActive = (nodeId) => {
      const activeId = hoverId || selectedId;
      return Boolean(
        activeId &&
          allLinks.some(
            (link) =>
              (linkEndpointId(link.source) === activeId &&
                linkEndpointId(link.target) === nodeId) ||
              (linkEndpointId(link.target) === activeId &&
                linkEndpointId(link.source) === nodeId)
          )
      );
    };
    const filteredNodes = () => {
      const types = activeTypes();
      const query = searchTerm();
      const showOrphans = orphansInput?.checked !== false;
      const matches = allNodes.filter((node) => {
        const typeMatch = types.has(node.type);
        const orphanMatch = showOrphans || (degreeById.get(node.id) || 0) > 0;
        const textMatch =
          !query ||
          node.id.toLowerCase().includes(query) ||
          node.title.toLowerCase().includes(query);
        return typeMatch && orphanMatch && textMatch;
      });
      if (!centerId || matches.some((node) => node.id === centerId)) {
        return matches;
      }
      const center = allNodes.find((node) => node.id === centerId);
      return center ? [center, ...matches] : matches;
    };
    const pageCountFor = (items) => {
      if (items.length <= pageSize) {
        return 1;
      }
      if (!centerId) {
        return Math.max(1, Math.ceil(items.length / pageSize));
      }
      return Math.max(1, Math.ceil((items.length - 1) / Math.max(1, pageSize - 1)));
    };
    const pageNodes = () => {
      const items = filteredNodes();
      if (items.length <= pageSize) {
        return items;
      }
      if (!centerId) {
        return items.slice((page - 1) * pageSize, page * pageSize);
      }
      const center = items.find((node) => node.id === centerId);
      const neighbors = items.filter((node) => node.id !== centerId);
      return [
        ...(center ? [center] : []),
        ...neighbors.slice((page - 1) * (pageSize - 1), page * (pageSize - 1))
      ];
    };
    const graphSize = () => {
      const rect = canvasHost.getBoundingClientRect();
      const compactGraph = host.classList.contains("compact");
      return {
        width: Math.max(compactGraph ? 260 : 320, Math.round(rect.width || 720)),
        height: Math.max(compactGraph ? 224 : 360, Math.round(rect.height || 520))
      };
    };
    const cloneNode = (node, index, total) => {
      const cached = positions[node.id];
      const role = nodeRole(node.id);
      const angle = (Math.PI * 2 * index) / Math.max(1, total);
      const clone = {
        ...node,
        role,
        val: Math.max(1, 1 + Math.sqrt(degreeById.get(node.id) || 0))
      };
      if (cached?.pinned) {
        clone.x = cached.x;
        clone.y = cached.y;
        clone.fx = cached.fx;
        clone.fy = cached.fy;
        clone.pinned = true;
      } else if (role === "center") {
        clone.x = 0;
        clone.y = 0;
      } else if (role === "dependency") {
        clone.x = -70;
        clone.y = -35 + index * 20;
      } else if (role === "dependent") {
        clone.x = 70;
        clone.y = -35 + index * 20;
      } else {
        clone.x = Math.cos(angle) * 90;
        clone.y = Math.sin(angle) * 70;
      }
      return clone;
    };
    const pageGraphData = () => {
      const selectedNodes = pageNodes();
      const ids = new Set(selectedNodes.map((node) => node.id));
      return {
        nodes: selectedNodes.map((node, index) =>
          cloneNode(node, index, selectedNodes.length)
        ),
        links: allLinks
          .filter((link) => {
            const sourceId = linkEndpointId(link.source);
            const targetId = linkEndpointId(link.target);
            return ids.has(sourceId) && ids.has(targetId);
          })
          .map((link) => ({
            source: linkEndpointId(link.source),
            target: linkEndpointId(link.target)
          }))
      };
    };
    const isActiveLink = (link) => {
      const activeId = hoverId || selectedId;
      const sourceId = linkEndpointId(link.source);
      const targetId = linkEndpointId(link.target);
      return Boolean(activeId && (sourceId === activeId || targetId === activeId));
    };
    const updatePageControls = () => {
      const count = pageCountFor(filteredNodes());
      page = Math.min(Math.max(1, page), count);
      if (pageOutput) {
        pageOutput.textContent = `${page} / ${count}`;
      }
      if (previousButton instanceof HTMLButtonElement) {
        previousButton.disabled = page <= 1;
      }
      if (nextButton instanceof HTMLButtonElement) {
        nextButton.disabled = page >= count;
      }
    };
    const drawNode = (node, ctx, globalScale) => {
      const activeId = hoverId || selectedId;
      const active = node.id === activeId || isLinkedToActive(node.id);
      const muted = Boolean(activeId && !active);
      const degree = degreeById.get(node.id) || 0;
      const baseRadius = Number(nodeSizeInput?.value || 8);
      const rawRadius = baseRadius + Math.sqrt(degree) * 1.4 +
        (node.role === "center" ? 2.5 : 0);
      const radius = rawRadius / Math.max(0.8, Math.sqrt(globalScale));
      const threshold = Number(labelThresholdInput?.value || 1.4);
      const minLinks = Number(labelMinLinksInput?.value || 0);
      const fadeStart = Math.max(0.1, threshold * 0.72);
      const fadeRange = Math.max(0.1, threshold - fadeStart);
      const zoomFade = Math.max(
        0,
        Math.min(1, (globalScale - fadeStart) / fadeRange)
      );
      const alwaysLabel =
        node.role === "center" ||
        node.id === hoverId ||
        node.id === selectedId ||
        Boolean(activeId && isLinkedToActive(node.id)) ||
        Boolean(node.pinned);
      const degreeEligible = minLinks === 0 || degree >= minLinks;
      const manualLabels = Boolean(labelsInput?.checked);
      const labelAlpha = manualLabels || alwaysLabel
        ? 1
        : degreeEligible
          ? zoomFade
          : 0;
      const textOpacity = Number(textOpacityInput?.value || 0.9);
      ctx.save();
      ctx.globalCompositeOperation = "source-over";
      ctx.shadowBlur = 0;
      ctx.shadowColor = "transparent";
      ctx.lineWidth = 0;
      ctx.globalAlpha = muted ? 0.22 : 1;
      ctx.beginPath();
      ctx.arc(node.x, node.y, radius, 0, Math.PI * 2);
      const fillColor = nodeColor(node);
      ctx.fillStyle = fillColor;
      ctx.fill();
      if (labelAlpha > 0.04) {
        const label = node.title.length > 26 ? `${node.title.slice(0, 23)}...` : node.title;
        const fontSize = Math.max(1.8, 11 / Math.max(0.35, globalScale));
        ctx.globalAlpha = (muted ? Math.min(labelAlpha, 0.28) : labelAlpha) * textOpacity;
        ctx.font = `700 ${fontSize}px Inter, system-ui, sans-serif`;
        ctx.lineWidth = 3 / Math.max(0.35, globalScale);
        ctx.strokeStyle = "#202320";
        ctx.fillStyle = "#e7e8df";
        ctx.strokeText(label, node.x + radius + 4, node.y + 4);
        ctx.fillText(label, node.x + radius + 4, node.y + 4);
      }
      ctx.restore();
    };

    readPositions();
    const Graph = ForceGraph()(canvasHost)
      .backgroundColor("#202320")
      .linkColor((link) =>
        isActiveLink(link) ? "rgba(244,201,93,0.82)" : "rgba(231,232,223,0.2)"
      )
      .linkWidth((link) => {
        const base = Number(linkWidthInput?.value || 1.2);
        return isActiveLink(link) ? base * 1.9 : base;
      })
      .linkDirectionalParticles(0)
      .linkDirectionalArrowLength(() => (arrowsInput?.checked ? 5 : 0))
      .linkDirectionalArrowRelPos(1)
      .nodeCanvasObject(drawNode)
      .nodeCanvasObjectMode(() => "replace")
      .nodePointerAreaPaint((node, color, ctx) => {
        const radius = Number(nodeSizeInput?.value || 8) + 7;
        ctx.globalCompositeOperation = "source-over";
        ctx.shadowBlur = 0;
        ctx.shadowColor = "transparent";
        ctx.fillStyle = color;
        ctx.beginPath();
        ctx.arc(node.x, node.y, radius, 0, 2 * Math.PI, false);
        ctx.fill();
      })
      .onNodeHover((node) => {
        hoverId = node?.id || "";
        if (selectionOutput) {
          selectionOutput.textContent = node ? `${node.title} · ${node.id}` : "";
        }
      })
      .onNodeClick((node) => {
        selectedId = node.id;
        if (selectionOutput) {
          selectionOutput.textContent = `${node.title} · ${node.id}`;
        }
        if (node.href) {
          window.location.href = node.href;
        }
      })
      .onNodeDrag(() => {
        Graph.d3ReheatSimulation();
      })
      .onNodeDragEnd((node) => {
        if (pinDraggedInput?.checked) {
          node.fx = node.x;
          node.fy = node.y;
          node.pinned = true;
          positions[node.id] = {
            x: node.x,
            y: node.y,
            fx: node.fx,
            fy: node.fy,
            pinned: true
          };
        } else {
          delete node.fx;
          delete node.fy;
          node.pinned = false;
          delete positions[node.id];
        }
        writePositions();
        Graph.d3ReheatSimulation();
      });

    const applyForces = () => {
      const centerStrength = Number(centerForceInput?.value || 0.24);
      Graph.d3Force("x", forceX(0).strength(centerStrength));
      Graph.d3Force("y", forceY(0).strength(centerStrength));
      Graph.d3Force("charge")?.strength(-Number(repelInput?.value || 240));
      Graph.d3Force("link")
        ?.distance(Number(linkDistanceInput?.value || 70))
        ?.strength(Number(linkForceInput?.value || 0.7));
    };
    const resize = () => {
      const size = graphSize();
      Graph.width(size.width).height(size.height);
    };
    const fitGraph = (duration = 450) => {
      const compactGraph = host.classList.contains("compact");
      const nodeCount = Graph.graphData().nodes?.length || 0;
      if (nodeCount > 0 && nodeCount <= 6) {
        Graph.centerAt(0, 0, duration);
        Graph.zoom(compactGraph ? 1.15 : 1.25, duration);
        return;
      }
      Graph.zoomToFit(duration, compactGraph ? 140 : 180);
    };
    const render = () => {
      updatePageControls();
      Graph.graphData(pageGraphData());
      applyForces();
      Graph.d3ReheatSimulation();
      window.setTimeout(() => fitGraph(450), 250);
      window.setTimeout(() => fitGraph(700), 950);
    };
    const renderFromFirstPage = () => {
      page = 1;
      render();
    };

    searchInput?.addEventListener("input", renderFromFirstPage);
    labelsInput?.addEventListener("change", () => {
      Graph.nodeCanvasObject(drawNode);
    });
    orphansInput?.addEventListener("change", renderFromFirstPage);
    colorTypeInput?.addEventListener("change", () => {
      if (colorTypeInput.checked && colorStatusInput instanceof HTMLInputElement) {
        colorStatusInput.checked = false;
      }
      Graph.nodeCanvasObject(drawNode);
    });
    colorStatusInput?.addEventListener("change", () => {
      if (colorStatusInput.checked && colorTypeInput instanceof HTMLInputElement) {
        colorTypeInput.checked = false;
      }
      Graph.nodeCanvasObject(drawNode);
    });
    newColorGroupButton?.addEventListener("click", () => {
      if (selectionOutput) {
        selectionOutput.textContent =
          currentLanguage() === "en"
            ? "Local color groups are UI-only in this slice."
            : "本轮颜色组仅作为本地界面规则。";
      }
    });
    arrowsInput?.addEventListener("change", () => {
      Graph.linkDirectionalArrowLength(() => (arrowsInput.checked ? 5 : 0));
    });
    for (const input of typeInputs) {
      input.addEventListener("change", renderFromFirstPage);
    }
    for (const input of [
      labelThresholdInput,
      textOpacityInput,
      labelMinLinksInput,
      nodeSizeInput,
      linkWidthInput,
      centerForceInput,
      repelInput,
      linkForceInput,
      linkDistanceInput
    ]) {
      input?.addEventListener("input", () => {
        applyForces();
        Graph.d3ReheatSimulation();
      });
    }
    previousButton?.addEventListener("click", () => {
      page -= 1;
      render();
    });
    nextButton?.addEventListener("click", () => {
      page += 1;
      render();
    });
    resetButton?.addEventListener("click", () => {
      positions = {};
      try {
        window.localStorage.removeItem(storageKey);
      } catch {
        // Storage may be unavailable.
      }
      selectedId = "";
      hoverId = "";
      for (const node of Graph.graphData().nodes || []) {
        delete node.fx;
        delete node.fy;
        node.pinned = false;
      }
      if (selectionOutput) {
        selectionOutput.textContent = "";
      }
      fitGraph(450);
      render();
    });
    unpinButton?.addEventListener("click", () => {
      positions = {};
      try {
        window.localStorage.removeItem(storageKey);
      } catch {
        // Storage may be unavailable.
      }
      for (const node of Graph.graphData().nodes || []) {
        delete node.fx;
        delete node.fy;
        node.pinned = false;
      }
      writePositions();
      Graph.d3ReheatSimulation();
    });
    settingsToggle?.addEventListener("click", () => setSettingsOpen(!settingsOpen));
    settingsClose?.addEventListener("click", () => setSettingsOpen(false));
    settingsScrim?.addEventListener("click", () => setSettingsOpen(false));
    host.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && settingsOpen) {
        setSettingsOpen(false);
      }
    });

    const observer = new ResizeObserver(() => resize());
    observer.observe(canvasHost);
    canvasHost.addEventListener(
      "wheel",
      (event) => {
        event.preventDefault();
        event.stopPropagation();
      },
      { passive: false }
    );
    let graphPointerActive = false;
    canvasHost.addEventListener("pointerdown", (event) => {
      graphPointerActive = true;
      event.stopPropagation();
    });
    canvasHost.addEventListener(
      "pointermove",
      (event) => {
        if (!graphPointerActive) {
          return;
        }
        event.preventDefault();
        event.stopPropagation();
      },
      { passive: false }
    );
    for (const eventName of ["pointerup", "pointercancel", "pointerleave"]) {
      canvasHost.addEventListener(eventName, (event) => {
        graphPointerActive = false;
        event.stopPropagation();
      });
    }
    canvasHost.addEventListener(
      "touchmove",
      (event) => {
        event.preventDefault();
        event.stopPropagation();
      },
      { passive: false }
    );
    resize();
    render();
  };

  const initAll = () => {
    document.querySelectorAll("[data-force-graph]").forEach(initCosheafGraph);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initAll, { once: true });
  } else {
    initAll();
  }
</script>
