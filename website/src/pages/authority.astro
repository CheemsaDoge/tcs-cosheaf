---
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHORITY_GUIDE, loadSiteData } from "../lib/siteData";

const data = await loadSiteData();
const flags = [
  ["Website authority / 网页权威", data.authority_boundaries.website_is_authority],
  ["Export source of truth / 导出是事实来源", data.authority_boundaries.export_is_source_of_truth],
  ["Frontend credentials / 前端凭据", data.authority_boundaries.frontend_credentials_allowed],
  ["Skipped is pass / skipped 是 pass", data.authority_boundaries.skipped_is_pass],
  ["Gate pass is truth / 门禁通过是真理", data.authority_boundaries.gate_pass_is_truth],
  ["Verifier pass is truth / 验证器通过是真理", data.authority_boundaries.verifier_pass_is_truth],
  ["AI output is human review / AI 输出是人工审阅", data.authority_boundaries.ai_output_is_human_review],
  ["Accepted write performed / 已执行 accepted 写入", data.authority_boundaries.accepted_write_performed]
];
---

<BaseLayout title="Authority Boundaries / 权限边界" eyebrow="Non-authority matrix / 非权威矩阵">
  <section class="notice-band">
    <strong>Five-minute boundary / 五分钟边界</strong>
    <span>Use the website to inspect context; use repository records and review policy for authority. / 用网页检查上下文；权威必须来自仓库记录和审阅策略。</span>
  </section>

  <section class="card-grid compact" aria-label="Authority boundary guide / 权限边界指南">
    {
      AUTHORITY_GUIDE.map((entry) => (
        <article class="info-card">
          <h2>{entry.title}</h2>
          <p>{entry.body}</p>
        </article>
      ))
    }
  </section>

  <section class="boundary-grid">
    {
      flags.map(([label, value]) => (
        <article class="boundary-cell">
          <span>{label}</span>
          <strong>{value ? "true / 是" : "false / 否"}</strong>
        </article>
      ))
    }
  </section>

  <section class="notice-list">
    {data.authority_boundaries.notices.map((notice) => <p>{notice}</p>)}
  </section>
</BaseLayout>
