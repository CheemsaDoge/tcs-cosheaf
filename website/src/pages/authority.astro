---
import BaseLayout from "../layouts/BaseLayout.astro";
import I18nText from "../components/I18nText.astro";
import { localized } from "../lib/i18n";
import { AUTHORITY_GUIDE, loadSiteData } from "../lib/siteData";

const data = await loadSiteData();
const flags = [
  [localized("Website authority", "网页权威"), data.authority_boundaries.website_is_authority],
  [localized("Export is source of truth", "导出是事实来源"), data.authority_boundaries.export_is_source_of_truth],
  [localized("Frontend credentials", "前端凭据"), data.authority_boundaries.frontend_credentials_allowed],
  [localized("Skipped is pass", "skipped 是 pass"), data.authority_boundaries.skipped_is_pass],
  [localized("Gate pass is truth", "准入检查通过是真理"), data.authority_boundaries.gate_pass_is_truth],
  [localized("Verifier pass is truth", "验证器通过是真理"), data.authority_boundaries.verifier_pass_is_truth],
  [localized("AI output is human review", "AI 输出是人工审阅"), data.authority_boundaries.ai_output_is_human_review],
  [localized("Accepted write performed", "已执行 accepted 写入"), data.authority_boundaries.accepted_write_performed]
];
---

<BaseLayout
  title={localized("Authority Boundaries", "权限边界")}
  eyebrow={localized("Non-authority matrix", "非权威矩阵")}
>
  <section class="notice-band">
    <strong><I18nText text={localized("Five-minute boundary", "五分钟边界")} /></strong>
    <span>
      <I18nText
        text={localized(
          "Use the website to inspect context; use repository records and review policy for authority.",
          "网页用于检查上下文；权威必须来自仓库记录和审阅策略。"
        )}
      />
    </span>
  </section>

  <section
    class="card-grid compact"
    aria-label="权限边界指南"
    data-i18n-aria-label-en="Authority boundary guide"
    data-i18n-aria-label-zh="权限边界指南"
  >
    {
      AUTHORITY_GUIDE.map((entry) => (
        <article class="info-card">
          <h2><I18nText text={entry.title} /></h2>
          <p><I18nText text={entry.body} /></p>
        </article>
      ))
    }
  </section>

  <section class="boundary-grid">
    {
      flags.map(([label, value]) => (
        <article class="boundary-cell">
          <span><I18nText text={label} /></span>
          <strong>
            <I18nText
              text={value ? localized("true", "是") : localized("false", "否")}
            />
          </strong>
        </article>
      ))
    }
  </section>

  <section class="notice-list">
    {data.authority_boundaries.notices.map((notice) => <p>{notice}</p>)}
  </section>
</BaseLayout>
