---
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHORITY_GUIDE, loadSiteData } from "../lib/siteData";

const data = await loadSiteData();
const flags = [
  ["Website authority", data.authority_boundaries.website_is_authority],
  ["Export source of truth", data.authority_boundaries.export_is_source_of_truth],
  ["Frontend credentials", data.authority_boundaries.frontend_credentials_allowed],
  ["Skipped is pass", data.authority_boundaries.skipped_is_pass],
  ["Gate pass is truth", data.authority_boundaries.gate_pass_is_truth],
  ["Verifier pass is truth", data.authority_boundaries.verifier_pass_is_truth],
  ["AI output is human review", data.authority_boundaries.ai_output_is_human_review],
  ["Accepted write performed", data.authority_boundaries.accepted_write_performed]
];
---

<BaseLayout title="Authority Boundaries" eyebrow="Non-authority matrix">
  <section class="notice-band">
    <strong>Five-minute boundary</strong>
    <span>Use the website to inspect context; use repository records and review policy for authority.</span>
  </section>

  <section class="card-grid compact" aria-label="Authority boundary guide">
    {
      AUTHORITY_GUIDE.map((entry) => (
        <article class="info-card">
          <h2>{entry.title}</h2>
          <p>{entry.body}</p>
        </article>
      ))
    }
  </section>

  <section class="boundary-grid">
    {
      flags.map(([label, value]) => (
        <article class="boundary-cell">
          <span>{label}</span>
          <strong>{value ? "true" : "false"}</strong>
        </article>
      ))
    }
  </section>

  <section class="notice-list">
    {data.authority_boundaries.notices.map((notice) => <p>{notice}</p>)}
  </section>
</BaseLayout>
