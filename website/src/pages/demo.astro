---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  PREVIEW_API_BASE,
  PREVIEW_AUTHORITY_WARNING,
  buildPreviewRequests
} from "../lib/previewActions";
import { loadSiteData } from "../lib/siteData";

const data = await loadSiteData();
const issue = data.issues.issues[0];
const previewRequests = buildPreviewRequests(data);
---

<BaseLayout title="Demo / 演示" eyebrow="Workspace fixture / 工作区夹具">
  <section class="split-layout">
    <article class="panel">
      <p class="section-kicker">Demo issue / 演示议题</p>
      <h2>{issue.title}</h2>
      <p>{issue.summary.split("\n\n")[0]}</p>
      <div class="tag-row">
        {issue.labels.map((label) => <span class="tag">{label}</span>)}
      </div>
    </article>

    <article class="panel">
      <p class="section-kicker">Demo-only data / 仅演示数据</p>
      <h2>Private fixture policy / 私有夹具策略</h2>
      <p>
        Demo private records are rendered only because the fixture marks them
        with demo tags and the export keeps full statements out of the sidecar.
        / 演示私有记录只有在夹具显式标记为 demo 时才会渲染，导出也不会把完整陈述放进 sidecar。
      </p>
      <div class="workflow-rail" aria-label="Demo workflow / 演示工作流">
        <span>export / 导出</span>
        <span>sanitize / 脱敏</span>
        <span>render / 渲染</span>
      </div>
    </article>
  </section>

  <section class="panel preview-panel">
    <div class="card-heading">
      <div>
        <p class="section-kicker">Preview actions / 预览动作</p>
        <h2>Dry-run action previews / Dry-run 动作预览</h2>
      </div>
      <span class="badge warning">preview only / 仅预览</span>
    </div>
    <p class="preview-warning">{PREVIEW_AUTHORITY_WARNING}</p>
    <div class="preview-toolbar" aria-label="Preview actions / 预览动作">
      {
        previewRequests.map((request) => (
          <button
            class="preview-button"
            type="button"
            data-preview-action={request.id}
          >
            {request.label}
          </button>
        ))
      }
    </div>
    <pre class="json-block preview-output" data-preview-output>
Select a preview action. The response will show planned files and actions from the local API.
选择一个预览动作。响应会显示本地 API 规划的文件和动作。</pre>
  </section>

  <script define:vars={{ previewRequests, apiBase: PREVIEW_API_BASE }}>
    const output = document.querySelector("[data-preview-output]");
    const requests = new Map(
      previewRequests.map((request) => [request.id, request])
    );

    document.querySelectorAll("[data-preview-action]").forEach((button) => {
      button.addEventListener("click", async () => {
        const request = requests.get(button.getAttribute("data-preview-action"));
        if (!request || !output) {
          return;
        }

        const endpoint = `${apiBase}${request.endpoint}`;
        button.setAttribute("disabled", "");
        button.setAttribute("aria-busy", "true");
        output.textContent = JSON.stringify(
          {
            endpoint,
            request: request.payload,
            status: "pending"
          },
          null,
          2
        );

        try {
          const response = await fetch(endpoint, {
            method: request.method,
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(request.payload)
          });
          const payload = await response.json();
          output.textContent = JSON.stringify(
            {
              endpoint,
              request: request.payload,
              status: response.status,
              response: payload
            },
            null,
            2
          );
        } catch (error) {
          output.textContent = JSON.stringify(
            {
              endpoint,
              request: request.payload,
              status: "error",
              error: error instanceof Error ? error.message : String(error)
            },
            null,
            2
          );
        } finally {
          button.removeAttribute("disabled");
          button.removeAttribute("aria-busy");
        }
      });
    });
  </script>
</BaseLayout>
