---
import ForceGraph from "../components/ForceGraph.astro";
import I18nText from "../components/I18nText.astro";
import RelationshipTags from "../components/RelationshipTags.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { localized } from "../lib/i18n";
import {
  GRAPH_PAGE_SIZE,
  artifactHref,
  dependenciesFor,
  dependentsFor,
  graphLayoutMode,
  loadSiteData
} from "../lib/siteData";

const data = await loadSiteData();
const layoutMode = graphLayoutMode(data.graph.nodes.length);
const nodeLimitNotice =
  layoutMode === "empty"
    ? localized(
        "No dependency graph nodes were exported.",
        "没有导出依赖图谱节点。"
      )
    : localized(
        "Obsidian-style graph view: draggable nodes, panning, zooming, filters, and force controls. It remains display context only.",
        "Obsidian 风格图谱：节点可拖动，画布可平移缩放，并提供过滤与力参数设置；它仍只是展示上下文。"
      );
---

<BaseLayout
  title={localized("Graph", "图谱")}
  eyebrow={localized("Obsidian-style dependency view", "Obsidian 风格依赖视图")}
>
  <section class="notice-band">
    <strong><I18nText text={localized("Graph boundary", "图谱边界")} /></strong>
    <span><I18nText text={nodeLimitNotice} /></span>
  </section>

  {
    layoutMode === "empty" ? (
      <section class="panel">
        <p class="empty-state">
          <I18nText
            text={localized(
              "No graph nodes were exported.",
              "没有导出图谱节点。"
            )}
          />
        </p>
      </section>
    ) : (
      <ForceGraph
        id="artifact-global-graph"
        nodes={data.graph.nodes}
        edges={data.graph.edges}
        pageSize={GRAPH_PAGE_SIZE}
        ariaLabel={localized("Artifact dependency graph", "工件依赖图谱")}
      />
    )
  }

  <details class="graph-detail-panel">
    <summary><I18nText text={localized("Graph edges", "图谱边")} /></summary>
    <section
      class="table-panel compact"
      aria-label="图谱边"
      data-i18n-aria-label-en="Graph edges"
      data-i18n-aria-label-zh="图谱边"
      data-paginated-list
      data-page-size="12"
    >
      <div class="table-head graph-table">
        <span><I18nText text={localized("Source", "源")} /></span>
        <span><I18nText text={localized("Target", "目标")} /></span>
      </div>
      {
        data.graph.edges.length > 0 ? (
          data.graph.edges.map((edge) => (
            <div class="table-row graph-table paginated-row">
              <code>{edge.source_id}</code>
              <code>{edge.target_id}</code>
            </div>
          ))
        ) : (
          <div class="table-row empty-row">
            <span>
              <I18nText
                text={localized(
                  "No graph edges were exported.",
                  "没有导出图谱边。"
                )}
              />
            </span>
          </div>
        )
      }
      <div class="list-pagination" data-list-pagination>
        <button type="button" data-list-prev>
          <I18nText text={localized("Previous", "上一页")} />
        </button>
        <output data-list-page>1 / 1</output>
        <button type="button" data-list-next>
          <I18nText text={localized("Next", "下一页")} />
        </button>
      </div>
    </section>
  </details>

  <details class="graph-detail-panel">
    <summary><I18nText text={localized("Neighborhood details", "邻域详情")} /></summary>
    <section
      class="card-grid compact"
      data-paginated-list
      data-page-size="9"
      aria-label="图谱邻域"
      data-i18n-aria-label-en="Graph neighborhoods"
      data-i18n-aria-label-zh="图谱邻域"
    >
      {
        data.graph.nodes.length > 0 ? data.graph.nodes.map((node) => {
          const deps = dependenciesFor(node.artifact_id, data.graph.edges).map((id) => ({
            id,
            href: artifactHref(id)
          }));
          const revDeps = dependentsFor(node.artifact_id, data.graph.edges).map((id) => ({
            id,
            href: artifactHref(id)
          }));
          return (
            <article class="info-card paginated-row">
              <h2><a href={artifactHref(node.artifact_id)}>{node.title}</a></h2>
              <p>{node.artifact_id}</p>
              <div class="neighborhood-grid">
                <div>
                  <strong><I18nText text={localized("Depends on", "依赖")} /></strong>
                  <RelationshipTags
                    items={deps}
                    title={localized("Depends on", "依赖")}
                  />
                </div>
                <div>
                  <strong><I18nText text={localized("Used by", "被使用于")} /></strong>
                  <RelationshipTags
                    items={revDeps}
                    title={localized("Used by", "被使用于")}
                  />
                </div>
              </div>
            </article>
          );
        }) : (
          <p class="empty-state">
            <I18nText
              text={localized(
                "No graph neighborhoods were exported.",
                "没有导出图谱邻域。"
              )}
            />
          </p>
        )
      }
      <div class="list-pagination" data-list-pagination>
        <button type="button" data-list-prev>
          <I18nText text={localized("Previous", "上一页")} />
        </button>
        <output data-list-page>1 / 1</output>
        <button type="button" data-list-next>
          <I18nText text={localized("Next", "下一页")} />
        </button>
      </div>
    </section>
  </details>

</BaseLayout>
