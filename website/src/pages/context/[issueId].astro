---
import BaseLayout from "../../layouts/BaseLayout.astro";
import I18nText from "../../components/I18nText.astro";
import MarkdownRenderer from "../../components/MarkdownRenderer.astro";
import { localized } from "../../lib/i18n";
import {
  artifactById,
  artifactHref,
  contextPackForIssue,
  issueById,
  loadSiteData
} from "../../lib/siteData";

export async function getStaticPaths() {
  const data = await loadSiteData();
  return data.context_packs.context_packs.map((pack) => ({
    params: { issueId: pack.issue_id }
  }));
}

const data = await loadSiteData();
const issueId = Astro.params.issueId ?? "";
const pack = contextPackForIssue(issueId, data);
const issue = issueById(issueId, data);
if (!pack || !issue) {
  throw new Error(`Unknown related material bundle: ${issueId}`);
}
---

<BaseLayout
  title={localized(`Related material: ${issue.title}`, `相关资料：${issue.title}`)}
  eyebrow={localized("Related material", "相关资料")}
>
  <section class="split-layout">
    <article class="panel">
      <p class="section-kicker"><I18nText text={localized("Issue material", "议题资料")} /></p>
      <h2>{pack.issue_id}</h2>
      <p
        data-i18n-en={`${pack.card_count} cards selected as related material.`}
        data-i18n-zh={`已选择 ${pack.card_count} 张相关资料卡片。`}
      >已选择 {pack.card_count} 张相关资料卡片。</p>
      <div class="tag-row">
        <span class="tag">
          <I18nText text={localized("Public only", "仅公开")} />:
          <I18nText text={pack.public_only ? localized("yes", "是") : localized("no", "否")} />
        </span>
        <span class="tag">
          <I18nText text={localized("Private material", "私有资料")} />:
          <I18nText text={pack.private_context_included ? localized("yes", "是") : localized("no", "否")} />
        </span>
        <span class="tag">
          <I18nText text={localized("Sample private material", "样例私有资料")} />:
          <I18nText text={pack.demo_private_context_included ? localized("yes", "是") : localized("no", "否")} />
        </span>
      </div>
    </article>
    <article class="panel">
      <p class="section-kicker"><I18nText text={localized("Authority", "权限")} /></p>
      <h2><I18nText text={localized("For review only", "仅供审阅参考")} /></h2>
      <p>
        <I18nText
          text={localized(
            "These materials help a reviewer read the issue; they do not approve or promote anything.",
            "这些资料帮助审阅者阅读议题；它们不会批准或晋升任何内容。"
          )}
        />
      </p>
    </article>
  </section>

  <section class="card-grid">
    {
      pack.related_artifacts.map((id) => {
        const artifact = artifactById(id, data);
        return (
          <article class="info-card">
            <h2><a href={artifactHref(id)}>{artifact?.title ?? id}</a></h2>
            {
              artifact?.summary ? (
                <MarkdownRenderer content={artifact.summary} />
              ) : (
                <p>
                  <I18nText
                    text={localized(
                      "Artifact metadata was not exported.",
                      "工件元数据未导出。"
                    )}
                  />
                </p>
              )
            }
          </article>
        );
      })
    }
  </section>
</BaseLayout>
