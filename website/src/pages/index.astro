---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  graphLayoutMode,
  loadSiteData,
  shouldDrawGraphConnector
} from "../lib/siteData";

const data = await loadSiteData();
const edge = data.graph.edges[0];
const graphMode = graphLayoutMode(data.graph.nodes.length);
const showMiniConnector = shouldDrawGraphConnector(
  data.graph.nodes.length,
  data.graph.edges.length
);
---

<BaseLayout title="Workspace export / 工作区导出" eyebrow="Home / 首页">
  <section class="metric-grid" aria-label="Export summary / 导出摘要">
    <article class="metric-card">
      <span>Artifacts / 工件</span>
      <strong>{data.artifacts.count}</strong>
      <small>
        {data.artifacts.public_only ? "public/demo-safe export / 公开或演示安全导出" : "local export / 本地导出"}
      </small>
    </article>
    <article class="metric-card">
      <span>Issues / 议题</span>
      <strong>{data.issues.count}</strong>
      <small>repository workflow memory / 仓库工作流记忆</small>
    </article>
    <article class="metric-card">
      <span>Gate verdict / 门禁结论</span>
      <strong>{data.gates.verdict.replace("_", " ")}</strong>
      <small>static export did not run gates / 静态导出未运行门禁</small>
    </article>
    <article class="metric-card">
      <span>Graph edges / 图谱边</span>
      <strong>{data.graph.edges.length}</strong>
      <small>display context only / 仅作展示上下文</small>
    </article>
  </section>

  <section class="split-layout">
    <article class="panel">
      <p class="section-kicker">Demo workspace / 演示工作区</p>
      <h2>{data.workspace.workspace_name}</h2>
      <p>
        The scaffold renders the exported sidecar without repository writes,
        backend calls, provider calls, or GitHub credentials. / 此界面渲染导出的
        sidecar 数据，不写仓库、不调用后端或模型服务，也不使用 GitHub 凭据。
      </p>
      <div class="root-list">
        {
          data.workspace.kb_roots.map((root) => (
            <div class="root-row">
              <span>{root.name}</span>
              <code>{root.path}</code>
              <strong>{root.readonly ? "readonly / 只读" : "writable overlay / 可写覆盖层"}</strong>
            </div>
          ))
        }
      </div>
    </article>

    <article class="panel graph-preview">
      <p class="section-kicker">Dependency graph / 依赖图谱</p>
      <h2>{edge ? `${edge.source_id} -> ${edge.target_id}` : "No edges / 无边"}</h2>
      {
        graphMode === "empty" ? (
          <p class="empty-state">No graph nodes were exported. / 没有导出图谱节点。</p>
        ) : (
          <div
            class:list={["mini-graph", graphMode === "list" && "mini-graph-list"]}
            role="img"
            aria-label="Dependency graph preview / 依赖图谱预览"
          >
            {
              data.graph.nodes.map((node, index) => (
                <div
                  class:list={[
                    "mini-node",
                    graphMode === "pair" && (index === 0 ? "source" : "target"),
                    graphMode === "list" && "mini-list-node"
                  ]}
                >
                  <strong>{node.title}</strong>
                  <span>{node.status}</span>
                </div>
              ))
            }
            {showMiniConnector && <div class="mini-edge" aria-hidden="true"></div>}
          </div>
        )
      }
    </article>
  </section>

  <section class="notice-band">
    <strong>Authority boundary / 权限边界</strong>
    <span>{data.authority_boundaries.notices[2]}</span>
  </section>
</BaseLayout>
