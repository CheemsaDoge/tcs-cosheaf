---
import BaseLayout from "../layouts/BaseLayout.astro";
import I18nText from "../components/I18nText.astro";
import MarkdownRenderer from "../components/MarkdownRenderer.astro";
import { localized } from "../lib/i18n";
import {
  artifactHref,
  buildWorkbenchDashboard,
  loadSiteData,
  statusTone
} from "../lib/siteData";

const data = await loadSiteData();
const dashboard = buildWorkbenchDashboard(data);
const gateTone =
  dashboard.gateFailureCount > 0
    ? "tone-bad"
    : data.gates.verdict === "pass"
      ? "tone-good"
      : "tone-warning";
const firstIssue = dashboard.activeIssues[0];
const firstDraft = dashboard.draftReviewArtifacts[0];
const firstPromotionCandidate =
  dashboard.promotion.ready[0] ?? dashboard.promotion.blocked[0];
---

<BaseLayout
  title={localized("Review workspace", "审阅工作区")}
  eyebrow={localized("Dashboard", "总览")}
>
  <section class="dashboard-header">
    <div>
      <p class="section-kicker">
        <I18nText text={localized("Artifact -> review -> PR", "工件 -> 审阅 -> PR")} />
      </p>
      <h2>{data.workspace.workspace_name}</h2>
    </div>
    <div class="dashboard-status-line">
      <span class:list={["status-badge", gateTone]}>
        {data.gates.verdict.replace("_", " ")}
      </span>
      <span>
        <I18nText
          text={localized(
            `${dashboard.gateFailureCount} gate failures`,
            `${dashboard.gateFailureCount} 个准入失败`
          )}
        />
      </span>
    </div>
  </section>

  <section
    class="metric-grid"
    aria-label="工作区摘要"
    data-i18n-aria-label-en="Workspace summary"
    data-i18n-aria-label-zh="工作区摘要"
  >
    <article class="metric-card">
      <span><I18nText text={localized("Active issues", "活跃议题")} /></span>
      <strong>{dashboard.activeIssues.length}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Drafts needing review", "待审草稿")} /></span>
      <strong>{dashboard.draftReviewArtifacts.length}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Promotion ready", "可晋升")} /></span>
      <strong>{dashboard.promotion.ready.length}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Promotion blocked", "晋升阻断")} /></span>
      <strong>{dashboard.promotion.blocked.length}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Artifacts", "工件")} /></span>
      <strong>{data.artifacts.count}</strong>
    </article>
  </section>

  <section class="dashboard-layout">
    <article class="dashboard-panel dashboard-panel-wide">
      <div class="dashboard-panel-heading">
        <h2><I18nText text={localized("Work requiring attention", "需要处理的工作")} /></h2>
        <a class="text-link" href="/issues/">
          <I18nText text={localized("Issues", "议题")} />
        </a>
      </div>
      <div class="dashboard-list">
        {
          dashboard.activeIssues.slice(0, 3).map((issue) => (
            <a class="dashboard-row" href={`/issues/${encodeURIComponent(issue.id)}/`}>
              <span>
                <strong><MarkdownRenderer content={issue.title} inline /></strong>
                <small>{issue.id}</small>
              </span>
              <span class="badge warning">{issue.status}</span>
            </a>
          ))
        }
        {
          dashboard.activeIssues.length === 0 && (
            <p class="empty-state">
              <I18nText text={localized("No active issues.", "没有活跃议题。")} />
            </p>
          )
        }
      </div>
    </article>

    <article class="dashboard-panel">
      <div class="dashboard-panel-heading">
        <h2><I18nText text={localized("Draft review", "草稿审阅")} /></h2>
        <a class="text-link" href="/artifacts/">
          <I18nText text={localized("Artifacts", "工件")} />
        </a>
      </div>
      <div class="dashboard-list">
        {
          dashboard.draftReviewArtifacts.slice(0, 3).map((artifact) => (
            <a class="dashboard-row" href={artifactHref(artifact.id)}>
              <span>
                <strong><MarkdownRenderer content={artifact.title} inline /></strong>
                <small>{artifact.id}</small>
              </span>
              <span class:list={["badge", statusTone(artifact.review_state)]}>
                {artifact.review_state}
              </span>
            </a>
          ))
        }
        {
          dashboard.draftReviewArtifacts.length === 0 && (
            <p class="empty-state">
              <I18nText text={localized("No draft review queue.", "没有待审草稿。")} />
            </p>
          )
        }
      </div>
    </article>

    <article class="dashboard-panel">
      <div class="dashboard-panel-heading">
        <h2><I18nText text={localized("Promotion", "晋升")} /></h2>
        {
          firstPromotionCandidate && (
            <a
              class="text-link"
              href={`/artifacts/${encodeURIComponent(firstPromotionCandidate.id)}/promotion/`}
            >
              <I18nText text={localized("Check", "检查")} />
            </a>
          )
        }
      </div>
      <div class="dashboard-stat-pair">
        <span>
          <strong>{dashboard.promotion.ready.length}</strong>
          <I18nText text={localized("ready", "可晋升")} />
        </span>
        <span>
          <strong>{dashboard.promotion.blocked.length}</strong>
          <I18nText text={localized("blocked", "阻断")} />
        </span>
      </div>
    </article>

    <article class="dashboard-panel">
      <div class="dashboard-panel-heading">
        <h2><I18nText text={localized("Gate failures", "准入失败")} /></h2>
        <a class="text-link" href="/gates/">
          <I18nText text={localized("Gate", "准入")} />
        </a>
      </div>
      {
        dashboard.gateFailureCount > 0 ? (
          <p>
            <I18nText
              text={localized(
                "Resolve blocking gate rows before review or promotion.",
                "审阅或晋升前先处理阻断行。"
              )}
            />
          </p>
        ) : (
          <p>
            <I18nText
              text={localized(
                "No blocking gate rows exported.",
                "没有导出的阻断行。"
              )}
            />
          </p>
        )
      }
    </article>

    <article class="dashboard-panel">
      <div class="dashboard-panel-heading">
        <h2><I18nText text={localized("Recent actions", "最近操作")} /></h2>
        <a class="text-link" href="/forge/submit/">
          <I18nText text={localized("Forge", "Forge")} />
        </a>
      </div>
      <div class="dashboard-list">
        {
          dashboard.recentActions.map((action) => (
            <span class="dashboard-row">
              <span>
                <strong><I18nText text={action.label} /></strong>
                {action.meta && <small><I18nText text={action.meta} /></small>}
              </span>
            </span>
          ))
        }
        {
          dashboard.recentActions.length === 0 && (
            <p class="empty-state">
              <I18nText
                text={localized(
                  "No web or forge audit rows exported.",
                  "没有导出的 web 或 forge 审计行。"
                )}
              />
            </p>
          )
        }
      </div>
    </article>

    <article class="dashboard-panel">
      <div class="dashboard-panel-heading">
        <h2><I18nText text={localized("Recent PRs", "最近 PR")} /></h2>
        <a class="text-link" href="/forge/pr-status/">
          <I18nText text={localized("PR status", "PR 状态")} />
        </a>
      </div>
      <div class="dashboard-list">
        {
          dashboard.recentPrLinks.map((link) => (
            <a class="dashboard-row" href={link.href}>
              <span>
                <strong><I18nText text={link.label} /></strong>
                {link.meta && <small><I18nText text={link.meta} /></small>}
              </span>
            </a>
          ))
        }
        {
          dashboard.recentPrLinks.length === 0 && (
            <p class="empty-state">
              <I18nText
                text={localized(
                  "No GitHub PR links exported.",
                  "没有导出的 GitHub PR 链接。"
                )}
              />
            </p>
          )
        }
      </div>
    </article>
  </section>

  <section
    class="dashboard-action-groups"
    aria-label="任务操作"
    data-i18n-aria-label-en="Task actions"
    data-i18n-aria-label-zh="任务操作"
  >
    <div>
      <strong><I18nText text={localized("Issue -> material", "议题 -> 资料")} /></strong>
      <a class="button-link" href={firstIssue ? `/issues/${encodeURIComponent(firstIssue.id)}/` : "/issues/"}>
        <I18nText text={localized("Open issue", "打开议题")} />
      </a>
      <a class="button-link secondary" href={firstIssue ? `/context/${encodeURIComponent(firstIssue.id)}/` : "/issues/"}>
        <I18nText text={localized("Related material", "相关资料")} />
      </a>
    </div>
    <div>
      <strong><I18nText text={localized("Artifact review", "工件审阅")} /></strong>
      <a class="button-link" href={firstDraft ? `/artifacts/${encodeURIComponent(firstDraft.id)}/review-packet/` : "/artifacts/"}>
        <I18nText text={localized("Review summary", "审阅摘要")} />
      </a>
      <a class="button-link secondary" href={firstDraft ? `/artifacts/${encodeURIComponent(firstDraft.id)}/review-decision/` : "/artifacts/"}>
        <I18nText text={localized("Human review", "人工审阅")} />
      </a>
    </div>
    <div>
      <strong><I18nText text={localized("Gate -> promotion", "准入 -> 晋升")} /></strong>
      <a class="button-link" href="/gates/">
        <I18nText text={localized("Validate / gate", "验证 / 准入")} />
      </a>
      <a class="button-link secondary" href={firstPromotionCandidate ? `/artifacts/${encodeURIComponent(firstPromotionCandidate.id)}/promotion/` : "/artifacts/"}>
        <I18nText text={localized("Promotion", "晋升")} />
      </a>
    </div>
    <div>
      <strong><I18nText text={localized("Branch -> PR", "分支 -> PR")} /></strong>
      <a class="button-link" href="/forge/submit/">
        <I18nText text={localized("Forge PR", "Forge PR")} />
      </a>
      <a class="button-link secondary" href="/forge/pr-status/">
        <I18nText text={localized("PR status", "PR 状态")} />
      </a>
    </div>
  </section>

  <section class="dashboard-panel dashboard-next-actions">
    <div class="dashboard-panel-heading">
      <h2><I18nText text={localized("Suggested next actions", "建议下一步")} /></h2>
    </div>
    <div class="dashboard-list">
      {
        dashboard.nextActions.map((action) => (
          <a class="dashboard-row" href={action.href}>
            <span>
              <strong><I18nText text={action.label} /></strong>
              {action.meta && <small><I18nText text={action.meta} /></small>}
            </span>
          </a>
        ))
      }
    </div>
  </section>

  <section class="notice-band">
    <strong><I18nText text={localized("Authority boundary", "权限边界")} /></strong>
    <span>
      <I18nText
        text={localized(
          "The dashboard is workflow context. Accepted status still requires repository records, source metadata, validation, gate policy, human review, and explicit promotion.",
          "总览只是工作流上下文；accepted 状态仍需仓库记录、source metadata、验证、准入策略、人工审阅和显式晋升。"
        )}
      />
    </span>
    <a class="text-link" href="/authority/">
      <I18nText text={localized("Read boundary", "查看边界")} />
    </a>
  </section>
</BaseLayout>
