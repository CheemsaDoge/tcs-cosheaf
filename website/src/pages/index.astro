---
import BaseLayout from "../layouts/BaseLayout.astro";
import I18nText from "../components/I18nText.astro";
import { localized } from "../lib/i18n";
import { loadSiteData } from "../lib/siteData";

const data = await loadSiteData();
---

<BaseLayout
  title={localized("Workspace", "工作区")}
  eyebrow={localized("Home", "首页")}
>
  <section class="workbench-intro">
    <div>
      <p class="section-kicker">
        <I18nText text={localized("Human governance workbench", "人类治理工作台")} />
      </p>
      <h2>{data.workspace.workspace_name}</h2>
      <p>
        <I18nText
          text={localized(
            "Inspect repository artifacts, issues, dependency context, and gate results from exported Cosheaf state. The repository remains the source of truth.",
            "从导出的 Cosheaf 状态检查仓库工件、议题、依赖上下文和准入检查结果；仓库记录仍是唯一事实来源。"
          )}
        />
      </p>
    </div>
    <div class="authority-chip">
      <strong><I18nText text={localized("Display only", "仅展示")} /></strong>
      <span>
        <I18nText
          text={localized(
            "This page does not review, verify, accept, or promote artifacts.",
            "此页面不审阅、不验证、不接受、不晋升工件。"
          )}
        />
      </span>
    </div>
  </section>

  <section
    class="metric-grid"
    aria-label="工作区摘要"
    data-i18n-aria-label-en="Workspace summary"
    data-i18n-aria-label-zh="工作区摘要"
  >
    <article class="metric-card">
      <span><I18nText text={localized("Artifacts", "工件")} /></span>
      <strong>{data.artifacts.count}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Issues", "议题")} /></span>
      <strong>{data.issues.count}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Gate", "准入检查")} /></span>
      <strong>{data.gates.verdict.replace("_", " ")}</strong>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Graph edges", "图谱边")} /></span>
      <strong>{data.graph.edges.length}</strong>
    </article>
  </section>

  <section
    class="workbench-actions"
    aria-label="工作台入口"
    data-i18n-aria-label-en="Workbench actions"
    data-i18n-aria-label-zh="工作台入口"
  >
    <a class="workbench-action" href="/artifacts/">
      <strong><I18nText text={localized("Inspect artifacts", "检查工件")} /></strong>
      <span><I18nText text={localized("Review draft and accepted metadata.", "查看 draft 与 accepted 元数据。")} /></span>
    </a>
    <a class="workbench-action" href="/issues/">
      <strong><I18nText text={localized("Triage issues", "处理议题")} /></strong>
      <span><I18nText text={localized("Create, edit, and close local issues in live mode.", "在本地实时模式中新建、修改和关闭议题。")} /></span>
    </a>
    <a class="workbench-action" href="/graph/">
      <strong><I18nText text={localized("Explore graph", "探索图谱")} /></strong>
      <span><I18nText text={localized("Use a draggable dependency graph as context.", "使用可拖拽依赖图谱作为上下文。")} /></span>
    </a>
    <a class="workbench-action" href="/gates/">
      <strong><I18nText text={localized("Check gates", "查看准入检查")} /></strong>
      <span><I18nText text={localized("Skipped and not-run results stay separate from pass.", "skipped 和 not-run 不会被当作 pass。")} /></span>
    </a>
  </section>

  <section class="notice-band">
    <strong><I18nText text={localized("Authority boundary", "权限边界")} /></strong>
    <span>
      <I18nText
        text={localized(
          "Frontend output is context for humans. Accepted status enters only through repository records, source metadata, validation, gate policy, human review, and explicit promotion.",
          "前端输出只是人类上下文；accepted 状态只能通过仓库记录、source metadata、验证、准入检查策略、人类审阅和显式晋升获得。"
        )}
      />
    </span>
    <a class="text-link" href="/authority/">
      <I18nText text={localized("Read boundary", "查看边界")} />
    </a>
  </section>
</BaseLayout>
