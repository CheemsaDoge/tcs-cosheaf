---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  artifactById,
  artifactHref,
  issueHref,
  loadSiteData,
  statusExplanation,
  statusTone
} from "../../lib/siteData";

export async function getStaticPaths() {
  const data = await loadSiteData();
  return data.artifacts.artifacts.map((artifact) => ({
    params: { id: artifact.id }
  }));
}

const data = await loadSiteData();
const id = Astro.params.id ?? "";
const artifact = artifactById(id);
if (!artifact) {
  throw new Error(`Unknown artifact: ${id}`);
}
const relatedIssues = data.issues.issues.filter((issue) =>
  issue.related_artifacts.includes(artifact.id)
);
---

<BaseLayout title={artifact.title} eyebrow="Artifact detail">
  <section class="split-layout">
    <article class="panel">
      <p class="section-kicker">{artifact.type}</p>
      <h2>{artifact.id}</h2>
      <p>{artifact.summary}</p>
      <div class="tag-row">
        <span class:list={["badge", statusTone(artifact.status)]} title={statusExplanation(artifact.status)}>
          {artifact.status}
        </span>
        <span class:list={["badge", statusTone(artifact.verifier_state)]} title={statusExplanation(artifact.verifier_state)}>
          verifier: {artifact.verifier_state}
        </span>
        <span class="tag">review: {artifact.review_state}</span>
        <span class="tag">scope: {artifact.root_scope}</span>
      </div>
    </article>

    <article class="panel">
      <p class="section-kicker">Safe links</p>
      <h2>Sources and evidence</h2>
      {
        artifact.sources.length > 0 ? (
          <div class="related-list">
            {artifact.sources.map((source) => <span>{source}</span>)}
          </div>
        ) : (
          <p>No safe source links were exported for this demo fixture.</p>
        )
      }
      <p>Verifier state is exported as `{artifact.verifier_state}` and does not imply pass.</p>
    </article>
  </section>

  <section class="card-grid">
    <article class="info-card">
      <h2>Dependencies</h2>
      <div class="related-list">
        {
          artifact.depends_on.length > 0
            ? artifact.depends_on.map((dep) => <a href={artifactHref(dep)}>{dep}</a>)
            : <span>none</span>
        }
      </div>
    </article>
    <article class="info-card">
      <h2>Related issues</h2>
      <div class="related-list">
        {
          relatedIssues.length > 0
            ? relatedIssues.map((issue) => <a href={issueHref(issue.id)}>{issue.title}</a>)
            : <span>none</span>
        }
      </div>
    </article>
  </section>
</BaseLayout>
