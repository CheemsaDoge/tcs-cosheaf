---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import ConfirmationModal from "../../../components/ConfirmationModal.astro";
import DependencyImpact from "../../../components/DependencyImpact.astro";
import DiffViewer from "../../../components/DiffViewer.astro";
import GateStatusBadge from "../../../components/GateStatusBadge.astro";
import I18nText from "../../../components/I18nText.astro";
import PromotionReasonGroups from "../../../components/PromotionReasonGroups.astro";
import { localized } from "../../../lib/i18n";
import {
  PROMOTION_LABELS,
  PROMOTION_TARGET_STATES
} from "../../../lib/promotionWorkbench";
import {
  artifactById,
  dependentsFor,
  dependenciesFor,
  loadSiteData,
  statusTone
} from "../../../lib/siteData";

export async function getStaticPaths() {
  const data = await loadSiteData();
  return data.artifacts.artifacts.map((artifact) => ({
    params: { id: artifact.id }
  }));
}

const id = Astro.params.id ?? "";
const data = await loadSiteData();
const artifact = artifactById(id, data);
if (!artifact) {
  throw new Error(`Unknown artifact: ${id}`);
}
const dependencies = dependenciesFor(artifact.id, data.graph.edges);
const dependents = dependentsFor(artifact.id, data.graph.edges);
const none = localized("none", "无");
const blockers = [
  ...(artifact.status === "raw" || artifact.status === "draft"
    ? [localized("Artifact is still raw or draft.", "工件仍处于 raw 或 draft。")]
    : []),
  ...(artifact.review_state !== "human_reviewed" &&
  artifact.review_state !== "accepted"
    ? [localized("Human review is not complete.", "尚未完成人工审阅。")]
    : []),
  ...(data.gates.verdict !== "pass"
    ? [localized("Latest gate verdict is not pass.", "最新准入结果不是 pass。")]
    : [])
];
const promotionGroups = [
  {
    label: PROMOTION_LABELS.dependencies,
    items: dependencies.length ? dependencies : [none]
  },
  {
    label: PROMOTION_LABELS.sourceMetadata,
    items: artifact.sources.length ? artifact.sources : [none]
  },
  {
    label: PROMOTION_LABELS.verifierChecks,
    items: [artifact.verifier_state || none]
  },
  {
    label: PROMOTION_LABELS.missingRequirements,
    items: blockers.length
      ? blockers
      : [localized("No static blockers shown.", "静态摘要未显示阻断项。")]
  }
];
const canPreviewPromotion = data.runtime.mode === "live-local";
---

<BaseLayout
  title={localized(`Promotion: ${artifact.id}`, `晋升：${artifact.id}`)}
  eyebrow={localized("Promotion Workbench", "晋升工作台")}
>
  <section class="workbench-shell">
    <article class="panel workbench-main">
      <div class="panel-heading">
        <div>
          <p class="section-kicker">
            <I18nText text={PROMOTION_LABELS.promotionReadiness} />
          </p>
          <h2><I18nText text={PROMOTION_LABELS.checkPromotion} /></h2>
        </div>
        <span class:list={["badge", blockers.length ? "warning" : "good"]}>
          <I18nText
            text={blockers.length ? PROMOTION_LABELS.blocked : PROMOTION_LABELS.ready}
          />
        </span>
      </div>
      <p class="preview-warning">
        <I18nText text={PROMOTION_LABELS.authorityNotice} />
      </p>

      <div class="promotion-status-strip">
        <GateStatusBadge
          label={PROMOTION_LABELS.currentStatus}
          status={artifact.status}
          tone={statusTone(artifact.status)}
        />
        <GateStatusBadge
          label={PROMOTION_LABELS.reviewState}
          status={artifact.review_state}
          tone={statusTone(artifact.review_state)}
        />
        <GateStatusBadge
          label={PROMOTION_LABELS.gateChecks}
          status={data.gates.verdict}
          tone={statusTone(data.gates.verdict)}
        />
      </div>

      <DependencyImpact dependencies={dependencies} dependents={dependents} />
      <PromotionReasonGroups groups={promotionGroups} />

      {
        canPreviewPromotion ? (
          <form
            class="workbench-form"
            data-promotion-workbench-form
            data-mode={data.runtime.mode}
            data-api-base={data.runtime.api_base}
            data-artifact-id={artifact.id}
            data-output="#promotion-readiness-output"
            data-diff-output="#promotion-diff-output"
            data-required-confirmation="#promotion-required-confirmation"
          >
            <input name="artifactId" value={artifact.id} type="hidden" />
            <label>
              <I18nText text={PROMOTION_LABELS.targetState} />
              <select name="targetState">
                {PROMOTION_TARGET_STATES.map((target) => (
                  <option value={target}>{target}</option>
                ))}
              </select>
            </label>
            <label>
              <I18nText text={PROMOTION_LABELS.actor} />
              <input name="actor" autocomplete="name" required />
            </label>
            <label>
              <I18nText text={PROMOTION_LABELS.requiredConfirmation} />
              <input id="promotion-required-confirmation" readonly value="PROMOTE TO ACCEPTED" />
            </label>
            <label>
              <I18nText text={PROMOTION_LABELS.typedConfirmation} />
              <input name="typedConfirmation" autocomplete="off" />
            </label>
            <div class="preview-toolbar">
              <button class="preview-button" type="button" data-preview>
                <I18nText text={PROMOTION_LABELS.preview} />
              </button>
              <button class="preview-button danger" type="button" data-confirm disabled>
                <I18nText text={PROMOTION_LABELS.confirm} />
              </button>
            </div>
            <ConfirmationModal
              title={PROMOTION_LABELS.confirm}
              artifactId={artifact.id}
              targetState="accepted"
              requiredPhrase="PROMOTE TO ACCEPTED"
              notesLabel={PROMOTION_LABELS.promotionJustification}
              confirmLabel={PROMOTION_LABELS.confirm}
            />
          </form>
        ) : (
          <p>
            <I18nText text={PROMOTION_LABELS.liveLocalRequired} />
          </p>
        )
      }
    </article>

    <article class="panel preview-panel workbench-preview">
      <p class="section-kicker">
        <I18nText text={PROMOTION_LABELS.promotionPreview} />
      </p>
      <pre
        class="json-block preview-output"
        id="promotion-readiness-output"
        data-i18n-en="Preview output appears here."
        data-i18n-zh="预览结果会显示在这里。"
      >预览结果会显示在这里。</pre>
      <DiffViewer
        id="promotion-diff-output"
        title={localized("YAML diff", "YAML 差异")}
      />
    </article>
  </section>

  <script>
    import "../../../lib/promotionWorkbenchClient";
  </script>
</BaseLayout>
