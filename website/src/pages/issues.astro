---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  artifactById,
  contextHref,
  issueHref,
  loadSiteData,
  statusExplanation
} from "../lib/siteData";

const data = await loadSiteData();
---

<BaseLayout title="Issues / 议题" eyebrow="Repository workflow memory / 仓库工作流记忆">
  <section class="card-grid">
    {
      data.issues.issues.length > 0 ? (
        data.issues.issues.map((issue) => (
          <article class="info-card wide">
            <div class="card-heading">
              <h2><a href={issueHref(issue.id)}>{issue.title}</a></h2>
              <span class="badge warning" title={statusExplanation(issue.status)}>
                {issue.status}
              </span>
            </div>
            <p>{issue.summary.split("\n\n")[0]}</p>
            <p><a class="text-link" href={contextHref(issue.id)}>View context pack / 查看上下文包</a></p>
            <div class="related-list">
              {issue.related_artifacts.map((id) => {
                const artifact = artifactById(id, data);
                return <span>{artifact ? artifact.title : id}</span>;
              })}
            </div>
          </article>
        ))
      ) : (
        <p class="empty-state">No issue summaries were exported. / 没有导出议题摘要。</p>
      )
    }
  </section>
</BaseLayout>
