---
import BaseLayout from "../layouts/BaseLayout.astro";
import I18nText from "../components/I18nText.astro";
import { localized, textFor } from "../lib/i18n";
import {
  ARTIFACT_PAGE_SIZE,
  artifactHref,
  loadSiteData,
  statusExplanation,
  statusTone,
  uniqueSorted
} from "../lib/siteData";

const data = await loadSiteData();
const artifacts = data.artifacts.artifacts;
const statuses = uniqueSorted(artifacts.map((artifact) => artifact.status));
const types = uniqueSorted(artifacts.map((artifact) => artifact.type));
const domains = uniqueSorted(artifacts.flatMap((artifact) => artifact.domain));
---

<BaseLayout
  title={localized("Artifacts", "工件")}
  eyebrow={localized("Safe artifact cards", "安全工件卡片")}
>
  <section class="notice-band action-band">
    <div>
      <strong><I18nText text={localized("Artifact changes", "工件变更")} /></strong>
      <span>
        <I18nText
          text={localized(
            "Create and edit artifact records through draft changes, PR review, validation, and gate checks. This page does not create accepted knowledge.",
            "新建和修改工件应通过 draft 变更、PR 审阅、验证和准入检查；此页面不会创建 accepted 知识。"
          )}
        />
      </span>
    </div>
    <div class="preview-toolbar">
      <a class="button-link" href="/issues/create/">
        <I18nText text={localized("New artifact change", "新建工件变更")} />
      </a>
      <a class="button-link secondary" href="/demo/">
        <I18nText text={localized("Review PR path", "审阅 PR 入口")} />
      </a>
    </div>
  </section>

  <section
    class="filter-panel"
    aria-label="工件筛选"
    data-i18n-aria-label-en="Artifact filters"
    data-i18n-aria-label-zh="工件筛选"
  >
    <label>
      <I18nText text={localized("Status", "状态")} />
      <select id="status-filter">
        <option value="" data-i18n-en="All" data-i18n-zh="全部">全部</option>
        {statuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <label>
      <I18nText text={localized("Type", "类型")} />
      <select id="type-filter">
        <option value="" data-i18n-en="All" data-i18n-zh="全部">全部</option>
        {types.map((type) => <option value={type}>{type}</option>)}
      </select>
    </label>
    <label>
      <I18nText text={localized("Domain", "领域")} />
      <select id="domain-filter">
        <option value="" data-i18n-en="All" data-i18n-zh="全部">全部</option>
        {domains.map((domain) => <option value={domain}>{domain}</option>)}
      </select>
    </label>
  </section>

  <section
    class="table-panel"
    aria-label="工件列表"
    data-i18n-aria-label-en="Artifact list"
    data-i18n-aria-label-zh="工件列表"
    data-page-size={ARTIFACT_PAGE_SIZE}
  >
    <div class="table-head artifacts">
      <span><I18nText text={localized("Artifact", "工件")} /></span>
      <span><I18nText text={localized("Type", "类型")} /></span>
      <span><I18nText text={localized("Status", "状态")} /></span>
      <span><I18nText text={localized("Verifier", "验证器")} /></span>
    </div>
    {
      artifacts.length > 0 ? (
        artifacts.map((artifact) => (
          <article
            class="table-row artifacts artifact-row"
            data-status={artifact.status}
            data-type={artifact.type}
            data-domain={artifact.domain.join(" ")}
          >
            <div>
              <a class="row-title" href={artifactHref(artifact.id)}>{artifact.title}</a>
              <code>{artifact.id}</code>
              <p>{artifact.summary}</p>
            </div>
            <span>{artifact.type}</span>
            <span
              class:list={["badge", statusTone(artifact.status)]}
              title={textFor(statusExplanation(artifact.status))}
            >
              {artifact.status}
            </span>
            <span
              class:list={["badge", statusTone(artifact.verifier_state)]}
              title={textFor(statusExplanation(artifact.verifier_state))}
            >
              {artifact.verifier_state}
            </span>
          </article>
        ))
      ) : (
        <div class="table-row empty-row">
          <span>
            <I18nText
              text={localized(
                "No artifact cards were exported.",
                "没有导出工件卡片。"
              )}
            />
          </span>
        </div>
      )
    }
    <p class="empty-state" data-filter-empty hidden>
      <I18nText
        text={localized(
          "No artifacts match the current filters.",
          "没有工件匹配当前筛选条件。"
        )}
      />
    </p>
    <div class="list-pagination" data-list-pagination>
      <button type="button" data-list-prev>
        <I18nText text={localized("Previous", "上一页")} />
      </button>
      <output data-list-page>1 / 1</output>
      <button type="button" data-list-next>
        <I18nText text={localized("Next", "下一页")} />
      </button>
    </div>
  </section>

</BaseLayout>
