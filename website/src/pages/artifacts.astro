---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  artifactHref,
  loadSiteData,
  statusExplanation,
  statusTone,
  uniqueSorted
} from "../lib/siteData";

const data = await loadSiteData();
const artifacts = data.artifacts.artifacts;
const statuses = uniqueSorted(artifacts.map((artifact) => artifact.status));
const types = uniqueSorted(artifacts.map((artifact) => artifact.type));
const domains = uniqueSorted(artifacts.flatMap((artifact) => artifact.domain));
---

<BaseLayout title="Artifacts / 工件" eyebrow="Safe artifact cards / 安全工件卡片">
  <section class="filter-panel" aria-label="Artifact filters / 工件筛选">
    <label>
      Status / 状态
      <select id="status-filter">
        <option value="">All / 全部</option>
        {statuses.map((status) => <option value={status}>{status}</option>)}
      </select>
    </label>
    <label>
      Type / 类型
      <select id="type-filter">
        <option value="">All / 全部</option>
        {types.map((type) => <option value={type}>{type}</option>)}
      </select>
    </label>
    <label>
      Domain / 领域
      <select id="domain-filter">
        <option value="">All / 全部</option>
        {domains.map((domain) => <option value={domain}>{domain}</option>)}
      </select>
    </label>
  </section>

  <section class="table-panel" aria-label="Artifact list / 工件列表">
    <div class="table-head artifacts">
      <span>Artifact / 工件</span>
      <span>Type / 类型</span>
      <span>Status / 状态</span>
      <span>Verifier / 验证器</span>
    </div>
    {
      artifacts.length > 0 ? (
        artifacts.map((artifact) => (
          <article
            class="table-row artifacts artifact-row"
            data-status={artifact.status}
            data-type={artifact.type}
            data-domain={artifact.domain.join(" ")}
          >
            <div>
              <a class="row-title" href={artifactHref(artifact.id)}>{artifact.title}</a>
              <code>{artifact.id}</code>
              <p>{artifact.summary}</p>
            </div>
            <span>{artifact.type}</span>
            <span
              class:list={["badge", statusTone(artifact.status)]}
              title={statusExplanation(artifact.status)}
            >
              {artifact.status}
            </span>
            <span
              class:list={["badge", statusTone(artifact.verifier_state)]}
              title={statusExplanation(artifact.verifier_state)}
            >
              {artifact.verifier_state}
            </span>
          </article>
        ))
      ) : (
        <div class="table-row empty-row">
          <span>No artifact cards were exported. / 没有导出工件卡片。</span>
        </div>
      )
    }
    <p class="empty-state" data-filter-empty hidden>
      No artifacts match the current filters. / 没有工件匹配当前筛选条件。
    </p>
  </section>

  <script>
    const selects = [
      document.querySelector("#status-filter"),
      document.querySelector("#type-filter"),
      document.querySelector("#domain-filter")
    ];
    const rows = [...document.querySelectorAll(".artifact-row")];
    const emptyMessage = document.querySelector("[data-filter-empty]");
    const applyFilters = () => {
      const [status, type, domain] = selects.map((select) => select?.value ?? "");
      let visibleCount = 0;
      for (const row of rows) {
        const matches =
          (!status || row.dataset.status === status) &&
          (!type || row.dataset.type === type) &&
          (!domain || row.dataset.domain?.split(" ").includes(domain));
        row.toggleAttribute("hidden", !matches);
        if (matches) {
          visibleCount += 1;
        }
      }
      if (emptyMessage) {
        emptyMessage.hidden = rows.length === 0 || visibleCount > 0;
      }
    };
    for (const select of selects) {
      select?.addEventListener("change", applyFilters);
    }
  </script>
</BaseLayout>
