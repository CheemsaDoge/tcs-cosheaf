---
import BaseLayout from "../../layouts/BaseLayout.astro";
import I18nText from "../../components/I18nText.astro";
import MarkdownMathHint from "../../components/MarkdownMathHint.astro";
import MarkdownRenderer from "../../components/MarkdownRenderer.astro";
import { localized, textFor } from "../../lib/i18n";
import {
  artifactById,
  artifactHref,
  contextHref,
  issueById,
  loadSiteData,
  statusExplanation
} from "../../lib/siteData";
import { ISSUE_WORKBENCH_LABELS } from "../../lib/issueWorkbench";
import { FORGE_ISSUE_LABELS } from "../../lib/forgeWorkbench";

export async function getStaticPaths() {
  const data = await loadSiteData();
  return data.issues.issues.map((issue) => ({
    params: { id: issue.id }
  }));
}

const id = Astro.params.id ?? "";
let data = await loadSiteData();
let issue = issueById(id, data);
if (!issue) {
  const staticData = await loadSiteData({ env: { mode: "static" } });
  const staticIssue = issueById(id, staticData);
  if (staticIssue) {
    data = staticData;
    issue = staticIssue;
  }
}
if (!issue) {
  throw new Error(`Unknown issue: ${id}`);
}
const canWriteIssues = data.runtime.mode === "live-local";
const canCloseIssue = canWriteIssues && issue.status !== "closed";
const canPublishGitHubIssue = canWriteIssues && issue.status !== "closed";
const issueSourcePath = `issues/${issue.status === "closed" ? "closed" : "open"}/${issue.id}.yaml`;
---

<BaseLayout title={issue.title} eyebrow={localized("Issue detail", "议题详情")}>
  <section class="split-layout issue-detail-layout">
    <article class="panel issue-summary-panel">
      <div class="panel-heading">
        <div>
          <p class="section-kicker"><I18nText text={localized("Issue", "议题")} /></p>
          <h2>{issue.id}</h2>
        </div>
        <span class="badge warning" title={textFor(statusExplanation(issue.status))}>{issue.status}</span>
      </div>
      <MarkdownRenderer content={issue.summary} />
      <div class="preview-toolbar compact">
        {
          canWriteIssues ? (
            <a class="button-link" href={`/issues/${encodeURIComponent(issue.id)}/edit/`}>
              <I18nText text={ISSUE_WORKBENCH_LABELS.editIssue} />
            </a>
          ) : (
            <span class="tag"><I18nText text={localized("Read-only demo", "只读演示")} /></span>
          )
        }
        <a class="button-link secondary" href={contextHref(issue.id)}>
          <I18nText text={localized("Context pack", "上下文包")} />
        </a>
        <a class="button-link secondary" href={`/issues/${encodeURIComponent(issue.id)}/review-packet/`}>
          <I18nText text={localized("Review packet", "审阅包")} />
        </a>
      </div>
      <div class="tag-row">
        <span class="tag"><I18nText text={localized("Scope", "范围")} />: {issue.scope}</span>
        <span class="tag"><I18nText text={localized("Severity", "严重度")} />: {issue.severity}</span>
      </div>
    </article>
    <article class="panel compact-list-panel">
      <p class="section-kicker"><I18nText text={localized("Related artifacts", "相关工件")} /></p>
      <div class="compact-list">
        {
          issue.related_artifacts.map((id) => {
            const artifact = artifactById(id, data);
            return (
              <a class="compact-row" href={artifactHref(id)}>
                <span>{artifact?.title ?? id}</span>
                <strong>{artifact?.status ?? "unavailable"}</strong>
              </a>
            );
          })
        }
      </div>
    </article>
  </section>

  <section class="workbench-shell compact">
    <article class="panel workbench-main">
      <div class="panel-heading">
        <div>
          <p class="section-kicker"><I18nText text={FORGE_ISSUE_LABELS.publish} /></p>
          <h2><I18nText text={FORGE_ISSUE_LABELS.title} /></h2>
        </div>
      </div>
      <p class="preview-warning">
        <I18nText text={FORGE_ISSUE_LABELS.warning} />
      </p>
      {
        canPublishGitHubIssue ? (
          <form
            class="workbench-form"
            data-github-issue-publish-form
            data-mode={data.runtime.mode}
            data-api-base={data.runtime.api_base}
            data-output="#github-issue-publish-preview"
            data-url-output="#github-issue-publish-url"
          >
            <input type="hidden" name="sourcePath" value={issueSourcePath} />
            <div class="preview-toolbar">
              <button class="preview-button" type="button" data-preview>
                <I18nText text={FORGE_ISSUE_LABELS.preview} />
              </button>
              <button class="preview-button danger" type="submit" data-confirm disabled>
                <I18nText text={FORGE_ISSUE_LABELS.confirm} />
              </button>
            </div>
          </form>
        ) : (
          <p>
            <I18nText
              text={localized(
                "GitHub issue publishing requires a live open local issue.",
                "发布 GitHub 议题需要本地实时模式中的打开议题。"
              )}
            />
          </p>
        )
      }
    </article>
    <article class="panel preview-panel workbench-preview">
      <p class="section-kicker"><I18nText text={FORGE_ISSUE_LABELS.result} /></p>
      <a id="github-issue-publish-url" class="button-link secondary" hidden></a>
      <pre
        class="json-block preview-output"
        id="github-issue-publish-preview"
        data-i18n-en="Preview GitHub issue publication before creating it."
        data-i18n-zh="创建前先预览 GitHub 议题发布。"
      >创建前先预览 GitHub 议题发布。</pre>
    </article>
  </section>

  <section class="workbench-shell compact">
    <article class="panel workbench-main">
      <div class="panel-heading">
        <div>
          <p class="section-kicker"><I18nText text={ISSUE_WORKBENCH_LABELS.buildContext} /></p>
          <h2><I18nText text={localized("Issue context", "议题上下文")} /></h2>
        </div>
      </div>
      <p class="preview-warning">
        <I18nText text={ISSUE_WORKBENCH_LABELS.contextGuidance} />
      </p>
      {
        canWriteIssues ? (
          <form
            class="workbench-form"
            data-context-build-form
            data-mode={data.runtime.mode}
            data-api-base={data.runtime.api_base}
            data-issue-id={issue.id}
            data-output="#context-build-preview"
            data-latest-output="#context-latest-output"
          >
            <label>
              <I18nText text={localized("Role", "角色")} />
              <select name="role">
                <option value="orchestrator">orchestrator</option>
                <option value="reviewer">reviewer</option>
                <option value="researcher">researcher</option>
              </select>
            </label>
            <label>
              <I18nText text={localized("Max cards", "最大卡片数")} />
              <input name="maxCards" type="number" min="1" max="100" value="20" />
            </label>
            <details class="workbench-details">
              <summary><I18nText text={localized("Advanced options", "高级选项")} /></summary>
              <label>
                <I18nText text={localized("Full artifact budget", "完整工件预算")} />
                <input name="maxFullArtifacts" type="number" min="0" max="20" value="0" />
              </label>
            </details>
            <label class="checkbox-label">
              <input name="publicOnly" type="checkbox" />
              <I18nText text={localized("Public only", "仅公开内容")} />
            </label>
            <div class="preview-toolbar">
              <button class="preview-button" type="button" data-preview>
                <I18nText text={ISSUE_WORKBENCH_LABELS.preview} />
              </button>
              <button class="preview-button" type="submit" data-confirm disabled>
                <I18nText text={ISSUE_WORKBENCH_LABELS.confirm} />
              </button>
            </div>
          </form>
        ) : (
          <p>
            <I18nText
              text={localized(
                "Context builds require live local mode.",
                "构建上下文包需要本地实时模式。"
              )}
            />
          </p>
        )
      }
    </article>
    <article class="panel preview-panel workbench-preview">
      <p class="section-kicker"><I18nText text={ISSUE_WORKBENCH_LABELS.previewDiff} /></p>
      <pre
        class="json-block preview-output"
        id="context-build-preview"
        data-i18n-en="Preview a context build before writing it."
        data-i18n-zh="写入前先预览上下文构建。"
      >写入前先预览上下文构建。</pre>
      <details class="workbench-details">
        <summary><I18nText text={localized("Latest context", "最新上下文")} /></summary>
        <pre
          class="json-block preview-output"
          id="context-latest-output"
          data-i18n-en="Latest context pack appears here in live local mode."
          data-i18n-zh="本地实时模式下，最新上下文包会显示在这里。"
        >本地实时模式下，最新上下文包会显示在这里。</pre>
      </details>
    </article>
  </section>

  <section class="workbench-shell compact">
    <article class="panel workbench-main">
      <div class="panel-heading">
        <div>
          <p class="section-kicker"><I18nText text={ISSUE_WORKBENCH_LABELS.closeIssue} /></p>
          <h2><I18nText text={localized("Close with a reason", "填写关闭原因")} /></h2>
        </div>
      </div>
      {
        canCloseIssue ? (
          <form
            class="workbench-form"
            data-issue-close-form
            data-mode={data.runtime.mode}
            data-api-base={data.runtime.api_base}
            data-issue-id={issue.id}
            data-output="#issue-close-preview"
          >
            <label>
              <I18nText text={ISSUE_WORKBENCH_LABELS.closeReason} />
              <textarea name="reason" rows="4" required></textarea>
              <MarkdownMathHint />
            </label>
            <div class="preview-toolbar">
              <button class="preview-button" type="button" data-preview>
                <I18nText text={ISSUE_WORKBENCH_LABELS.preview} />
              </button>
              <button class="preview-button danger" type="submit" data-confirm disabled>
                <I18nText text={ISSUE_WORKBENCH_LABELS.confirm} />
              </button>
            </div>
          </form>
        ) : (
          <p>
            <I18nText
              text={localized(
                "Cannot close this issue in the current mode or status.",
                "当前模式或状态下无法关闭此议题。"
              )}
            />
          </p>
        )
      }
    </article>
    <article class="panel preview-panel workbench-preview">
      <p class="section-kicker"><I18nText text={ISSUE_WORKBENCH_LABELS.previewDiff} /></p>
      <pre
        class="json-block preview-output"
        id="issue-close-preview"
        data-i18n-en="Preview a close action before writing it."
        data-i18n-zh="写入前先预览关闭操作。"
      >写入前先预览关闭操作。</pre>
    </article>
  </section>

  <script>
    import "../../lib/issueWorkbenchClient";
  </script>
</BaseLayout>
