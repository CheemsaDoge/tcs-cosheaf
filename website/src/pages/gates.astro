---
import BaseLayout from "../layouts/BaseLayout.astro";
import I18nText from "../components/I18nText.astro";
import MarkdownRenderer from "../components/MarkdownRenderer.astro";
import { localized } from "../lib/i18n";
import {
  gateVerdictExplanation,
  loadSiteData,
  statusTone
} from "../lib/siteData";
import { CHECK_RUN_LABELS, summarizeCheckStatuses } from "../lib/gateWorkbench";

const data = await loadSiteData();
const checkStatuses = summarizeCheckStatuses(data.gates.gates);
const canRunChecks = data.runtime.mode === "live-local";
---

<BaseLayout
  title={localized("Gate Reports", "准入检查报告")}
  eyebrow={localized("Gate summary", "准入检查摘要")}
>
  <section class="workbench-shell compact">
    <article class="panel workbench-main">
      <div class="panel-heading">
        <div>
          <p class="section-kicker"><I18nText text={CHECK_RUN_LABELS.actions} /></p>
          <h2><I18nText text={localized("Workspace checks", "工作区检查")} /></h2>
        </div>
      </div>
      {
        canRunChecks ? (
          <div class="preview-toolbar">
            <button
              class="preview-button"
              type="button"
              data-check-run="validate"
              data-mode={data.runtime.mode}
              data-api-base={data.runtime.api_base}
              data-output="#check-run-output"
            >
              <I18nText text={CHECK_RUN_LABELS.runValidate} />
            </button>
            <button
              class="preview-button"
              type="button"
              data-check-run="gate"
              data-mode={data.runtime.mode}
              data-api-base={data.runtime.api_base}
              data-output="#check-run-output"
            >
              <I18nText text={CHECK_RUN_LABELS.runGate} />
            </button>
          </div>
        ) : (
          <p><I18nText text={localized("Live local mode only.", "仅本地实时模式。")} /></p>
        )
      }
    </article>
    <article class="panel preview-panel workbench-preview">
      <p class="section-kicker"><I18nText text={CHECK_RUN_LABELS.result} /></p>
      <pre
        class="json-block preview-output"
        id="check-run-output"
        data-i18n-en="Run output appears here."
        data-i18n-zh="运行结果会显示在这里。"
      ></pre>
    </article>
  </section>

  <section class="split-layout">
    <article class="panel">
      <p class="section-kicker"><I18nText text={localized("Verdict", "结论")} /></p>
      <h2>
        <span class:list={["badge", statusTone(data.gates.verdict)]}>
          {data.gates.verdict.replace("_", " ")}
        </span>
      </h2>
      <p><I18nText text={gateVerdictExplanation(data.gates)} /></p>
      <MarkdownRenderer content={data.gates.note} />
    </article>
    <article class="panel">
      <p class="section-kicker"><I18nText text={localized("Blocking state", "阻断状态")} /></p>
      <h2>
        {data.gates.blocking_issues.length}{" "}
        <I18nText text={localized("blocking issues", "个阻断问题")} />
      </h2>
      <p>
        <I18nText
          text={localized(
            "Skipped, missing, or unavailable checks are shown separately from pass.",
            "skipped、missing 或 unavailable 检查会与 pass 分开显示。"
          )}
        />
      </p>
    </article>
  </section>

  <section class="metric-grid">
    <article class="metric-card">
      <span><I18nText text={CHECK_RUN_LABELS.pass} /></span>
      <strong>{checkStatuses.pass}</strong>
      <small><I18nText text={localized("Passed checks", "通过的检查")} /></small>
    </article>
    <article class="metric-card">
      <span><I18nText text={CHECK_RUN_LABELS.fail} /></span>
      <strong>{checkStatuses.fail}</strong>
      <small><I18nText text={localized("Failed checks", "失败的检查")} /></small>
    </article>
    <article class="metric-card">
      <span><I18nText text={CHECK_RUN_LABELS.skipped} /></span>
      <strong>{checkStatuses.skipped}</strong>
      <small><I18nText text={localized("Skipped checks", "跳过的检查")} /></small>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Warnings", "警告")} /></span>
      <strong>{data.gates.nonblocking_issues.length}</strong>
      <small><I18nText text={localized("Nonblocking issues", "非阻断问题")} /></small>
    </article>
    <article class="metric-card">
      <span><I18nText text={localized("Reports", "报告")} /></span>
      <strong>{data.gates.report_paths.length}</strong>
      <small><I18nText text={localized("Static references", "静态引用")} /></small>
    </article>
  </section>

  <section class="split-layout">
    <article class="panel">
      <p class="section-kicker"><I18nText text={localized("Failures and warnings", "失败与警告")} /></p>
      <h2><I18nText text={localized("Blocking and nonblocking rows", "阻断与非阻断行")} /></h2>
      {
        data.gates.blocking_issues.length + data.gates.nonblocking_issues.length > 0 ? (
          <pre class="json-block">{JSON.stringify({
            blocking: data.gates.blocking_issues,
            nonblocking: data.gates.nonblocking_issues
          }, null, 2)}</pre>
        ) : (
          <p>
            <I18nText
              text={localized(
                "No blocking or nonblocking issue rows were exported.",
                "没有导出阻断或非阻断问题行。"
              )}
            />
          </p>
        )
      }
    </article>
    <article class="panel">
      <p class="section-kicker"><I18nText text={localized("PR checklist gate", "PR 清单准入检查")} /></p>
      <h2><I18nText text={localized("Report references", "报告引用")} /></h2>
      {
        data.gates.report_paths.length > 0 ? (
          <div class="related-list">
            {data.gates.report_paths.map((path) => <span>{path}</span>)}
          </div>
        ) : (
          <p>
            <I18nText
              text={localized(
                "No PR checklist gate report was exported for this fixture.",
                "此夹具没有导出 PR 清单准入检查报告。"
              )}
            />
          </p>
        )
      }
    </article>
  </section>
  <script>
    import "../lib/gateWorkbenchClient";
  </script>
</BaseLayout>
